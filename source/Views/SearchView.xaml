<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style TargetType="{x:Type SearchWindowGameItem}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type SearchWindowGameItem}">
          <DockPanel Margin="5,5,5,5">
            <Image
              DockPanel.Dock="Left"
              Width="32" Height="32"
              VerticalAlignment="Center"
              Name="PART_ImageGameIcon" RenderOptions.BitmapScalingMode="Fant">
              <Image.Style>
                <Style TargetType="Image">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding GameView.IsInstalled}" Value="False">
                      <Setter Property="Opacity" Value="0.5" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Image.Style>
            </Image>

            <StackPanel
              DockPanel.Dock="Left"
              Margin="10,0,0,0" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal">
                <TextBlock
                  Margin="0,0,5,0" VerticalAlignment="Center"
                  FontSize="{DynamicResource FontSizeLarge}"
                  FontWeight="SemiBold" Name="PART_TextName">
                  <TextBlock.Style>
                    <Style BasedOn="{StaticResource BaseTextBlockStyle}" TargetType="TextBlock">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding GameView.IsInstalled}" Value="False">
                          <Setter Property="Foreground" Value="{DynamicResource TextBrushDarker}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <Image
                  Width="18" Height="18"
                  Margin="5,0,5,0" VerticalAlignment="Center"
                  Name="PART_ImageLibraryIcon" Opacity="0.90"
                  RenderOptions.BitmapScalingMode="Fant" />
                <TextBlock
                  Margin="5,0,5,0" VerticalAlignment="Center"
                  Text="&#xef22;"
                  FontFamily="{StaticResource FontIcoFont}"
                  FontSize="16" Name="PART_ElemHiddenStatus" />
              </StackPanel>

              <ItemsControl Margin="0,5,0,0" Name="PART_ItemsAdditionalInfo">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Foreground="{DynamicResource TextBrushDarker}">
                      <TextBlock.Style>
                        <Style BasedOn="{StaticResource BaseTextBlockStyle}" TargetType="TextBlock">
                          <Setter Property="Margin" Value="5,0,0,0" />
                          <Setter Property="Text" Value="{Binding '', StringFormat='- {0}'}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource PreviousData}}" Value="{x:Null}">
                              <Setter Property="Margin" Value="0" />
                              <Setter Property="Text" Value="{Binding}" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
            </StackPanel>
          </DockPanel>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <DataTemplate x:Key="SearchWindowGameItemTemplate">
    <SearchWindowGameItem />
  </DataTemplate>

  <Style TargetType="{x:Type SearchWindowSearchItem}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type SearchWindowSearchItem}">
          <StackPanel Margin="5,2,5,2" Orientation="Horizontal">
            <Viewbox
              Width="32" Height="32"
              VerticalAlignment="Center">
              <ContentControl
                Margin="4" VerticalAlignment="Center"
                Focusable="False" Name="PART_ContentIcon" />
            </Viewbox>
            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
              <TextBlock
                VerticalAlignment="Center"
                FontSize="{DynamicResource FontSizeLarge}"
                FontWeight="Normal" Name="PART_TextName" />
              <TextBlock
                Margin="0,5,0,0" VerticalAlignment="Center"
                Foreground="{DynamicResource TextBrushDarker}"
                Name="PART_TextDescription" />
            </StackPanel>
          </StackPanel>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <DataTemplate x:Key="SearchWindowSearchItemTemplate">
    <SearchWindowSearchItem />
  </DataTemplate>

  <Style
    x:Key="SearchWindowSearchLabelButton"
    BasedOn="{StaticResource {x:Type Button}}"
    TargetType="Button">
    <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="Margin" Value="0,0,5,0" />
    <Setter Property="ContentTemplate">
      <Setter.Value>
        <DataTemplate>
          <StackPanel Orientation="Horizontal">
            <TextBlock
              MaxWidth="100"
              Margin="0,0,4,0"
              Text="{Binding}"
              TextTrimming="CharacterEllipsis" />
            <TextBlock Text="&#xeee4;" FontFamily="{StaticResource FontIcoFont}" />
          </StackPanel>
        </DataTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style
    x:Key="SearchWindowActionButton"
    BasedOn="{StaticResource {x:Type ToggleButton}}"
    TargetType="ToggleButton">
    <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    <Setter Property="Margin" Value="5,0,5,0" />
  </Style>

  <Style
    x:Key="SearchWindowInfoButton"
    BasedOn="{StaticResource {x:Type Button}}"
    TargetType="Button">
    <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="Margin" Value="10,0,5,0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Content" Value="&#xef50;" />
    <Setter Property="FontFamily" Value="{StaticResource FontIcoFont}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style
    x:Key="SearchWindowSettignsButton"
    BasedOn="{StaticResource {x:Type Button}}"
    TargetType="Button">
    <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="Margin" Value="5,0,5,0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Content" Value="&#xefb0;" />
    <Setter Property="FontFamily" Value="{StaticResource FontIcoFont}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style
    x:Key="SearchWindowStyle"
    BasedOn="{StaticResource StandardWindowStyle}"
    TargetType="WindowBase">
    <Setter Property="Background" Value="{DynamicResource NormalBrushDark}" />
    <Setter Property="Width" Value="800" />
    <Setter Property="SizeToContent" Value="Height" />
  </Style>

  <ControlTemplate x:Key="SearchWindowFilterNotification" TargetType="ContentControl">
    <Border HorizontalAlignment="Stretch" Background="{DynamicResource NormalBrushDark}">
      <TextBlock
        Style="{DynamicResource BaseTextBlockStyle}"
        Margin="10,0,0,0" VerticalAlignment="Center"
        Text="{TemplateBinding Content}"
        FontSize="{DynamicResource FontSizeLarge}" />
    </Border>
  </ControlTemplate>

  <Style
    x:Key="SearchWindowSearchBox"
    BasedOn="{StaticResource {x:Type TextBox}}"
    TargetType="TextBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    <Setter Property="FontSize" Value="{DynamicResource FontSizeLarger}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style
    x:Key="SearchWindowSearchDescription"
    BasedOn="{StaticResource BaseTextBlockStyle}"
    TargetType="TextBlock">
    <Setter Property="Margin" Value="5,0,0,0" />
    <Setter Property="Foreground" Value="LightGray" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FontSize" Value="{DynamicResource FontSizeLarge}" />
  </Style>

  <Style
    x:Key="SearchWindowSearchHint"
    BasedOn="{StaticResource BaseTextBlockStyle}"
    TargetType="TextBlock">
    <Setter Property="Margin" Value="10" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="FontSize" Value="{DynamicResource FontSizeLarge}" />
  </Style>

  <Style
    x:Key="SearchWindowList"
    BasedOn="{StaticResource {x:Type ListBox}}"
    TargetType="ListBox">
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="MaxHeight" Value="600" />
    <Setter Property="ItemContainerStyle">
      <Setter.Value>
        <Style TargetType="{x:Type ListBoxItem}">
          <Setter Property="SnapsToDevicePixels" Value="True" />
          <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
          <Setter Property="OverridesDefaultStyle" Value="True" />
          <Setter Property="Padding" Value="3" />
          <Setter Property="Margin" Value="0" />
          <Setter Property="HorizontalAlignment" Value="Stretch" />
          <Setter Property="VerticalAlignment" Value="Stretch" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="{x:Type ListBoxItem}">
                <Grid>
                  <Border
                    x:Name="HoverRectangle"
                    Visibility="Collapsed" IsHitTestVisible="False"
                    Background="#003f59"
                    CornerRadius="{DynamicResource ControlCornerRadius}" />
                  <Border
                    x:Name="SelectedRectangle"
                    Visibility="Collapsed" IsHitTestVisible="False"
                    Background="#003f59"
                    CornerRadius="{DynamicResource ControlCornerRadius}" />
                  <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                    <ContentPresenter
                      Margin="3,0,0,0"
                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                  </Border>
                </Grid>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Visibility" TargetName="SelectedRectangle" Value="Visible" />
                  </Trigger>
                  <Trigger Property="IsSelected" Value="true">
                    <Setter Property="Visibility" TargetName="SelectedRectangle" Value="Visible" />
                  </Trigger>
                  <MultiTrigger>
                    <MultiTrigger.Conditions>
                      <Condition Property="IsMouseOver" Value="True" />
                      <Condition Property="Selector.IsSelected" Value="False" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Visibility" TargetName="HoverRectangle" Value="Visible" />
                  </MultiTrigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style TargetType="{x:Type Library}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Library}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <TopPanel
              Grid.Row="0"
              Effect="{DynamicResource DefaultDropShadow}"
              Panel.ZIndex="999" />
            <FadeImage
              x:Name="PART_ImageBackground"
              Grid.Row="0" Grid.Column="0"
              Grid.RowSpan="2"
              HorizontalAlignment="Center" VerticalAlignment="Top"
              ClipToBounds="True" />

            <DockPanel Grid.Row="1">
              <FilterPanel
                x:Name="PART_FilterPanel"
                DockPanel.Dock="{Settings FilterPanelPosition}"
                Width="{Settings FilterPanelWitdh}"
                Visibility="{Settings FilterPanelVisible}" />

              <ExplorerPanel
                DockPanel.Dock="{Settings ExplorerPanelPosition}"
                Width="{Settings ExplorerPanelWitdh}"
                Visibility="{Settings ExplorerPanelVisible}" />

              <Grid>
                <LibraryDetailsView x:Name="PART_ViewDetails" />
                <LibraryGridView x:Name="PART_ViewGrid" />
                <LibraryListView x:Name="PART_ViewList" />
              </Grid>
            </DockPanel>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

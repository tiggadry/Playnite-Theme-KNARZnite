<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style
    x:Key="FilterPanelCheckBox"
    BasedOn="{StaticResource {x:Type CheckBox}}"
    TargetType="CheckBox">
    <Setter Property="Margin" Value="8,2,6,8" />
    <Style.Triggers>
      <Trigger Property="IsChecked" Value="{StaticResource False}">
        <Setter Property="Opacity" Value="0.70" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style
    x:Key="FilterPanelLabel"
    BasedOn="{StaticResource {x:Type Label}}"
    TargetType="Label">
    <Setter Property="Margin" Value="8,10,6,4" />
    <Style.Triggers>
      <Trigger Property="Tag" Value="{StaticResource False}">
        <Setter Property="Opacity" Value="0.6" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style
    x:Key="FilterPanelFilterSearchBox"
    BasedOn="{StaticResource {x:Type SearchBox}}"
    TargetType="SearchBox">
    <Setter Property="Margin" Value="8,0,6,0" />
    <Setter Property="ShowImage" Value="False" />
  </Style>

  <Style
    x:Key="FilterPanelFilterSelectionBox"
    BasedOn="{StaticResource {x:Type FilterSelectionBox}}"
    TargetType="FilterSelectionBox">
    <Setter Property="Margin" Value="8,0,6,0" />
  </Style>

  <Style
    x:Key="FilterPanelFilterEnumSelectionBox"
    BasedOn="{StaticResource {x:Type FilterEnumSelectionBox}}"
    TargetType="FilterEnumSelectionBox">
    <Setter Property="Margin" Value="8,0,6,0" />
  </Style>

  <Style
    x:Key="FilterPanelFilterStringSelectionBox"
    BasedOn="{StaticResource {x:Type FilterStringSelectionBox}}"
    TargetType="FilterStringSelectionBox">
    <Setter Property="Margin" Value="8,0,6,0" />
  </Style>

  <Style
    x:Key="FilterPresetButtonAction"
    BasedOn="{StaticResource {x:Type Button}}"
    TargetType="Button">
    <Setter Property="FontFamily" Value="{StaticResource FontIcoFont}" />
    <Setter Property="Padding" Value="5" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="DockPanel.Dock" Value="Right" />
  </Style>

  <Style TargetType="{x:Type FilterPanel}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type FilterPanel}">
          <Border
            Padding="10,0,10,0"
            Background="Transparent"
            BorderBrush="{DynamicResource PanelSeparatorBrush}">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="BorderThickness" Value="1,0,0,0" />
                <Style.Triggers>
                  <DataTrigger Binding="{Settings FilterPanelPosition}" Value="Left">
                    <Setter Property="BorderThickness" Value="0,0,1,0" />
                  </DataTrigger>
                  <DataTrigger Binding="{Settings ShowPanelSeparators}" Value="False">
                    <Setter Property="BorderThickness" Value="0" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <DockPanel Background="{TemplateBinding Background}">
              <DockPanel DockPanel.Dock="Top" Margin="10,8,5,5">
                <Button
                  Style="{StaticResource SimpleButton}"
                  DockPanel.Dock="Right"
                  Margin="0,0,5,0"
                  Content="r"
                  FontFamily="Marlett" Name="PART_ButtonClose" />
                <Button
                  Style="{StaticResource SimpleButton}"
                  DockPanel.Dock="Left"
                  HorizontalAlignment="Left"
                  Content="{StaticResource LOCClearFilters}"
                  Name="PART_ButtonClear" />
              </DockPanel>
              <DockPanel DockPanel.Dock="Top" Margin="8,0,6,5">
                <Button
                  x:Name="PART_ButtonDeleteFilter"
                  Style="{DynamicResource FilterPresetButtonAction}"
                  Content="&#xec53;" />
                <Button
                  x:Name="PART_ButtonRenameFilter"
                  Style="{DynamicResource FilterPresetButtonAction}"
                  Content="&#xec55;" />
                <Button
                  x:Name="PART_ButtonSaveFilter"
                  Style="{DynamicResource FilterPresetButtonAction}"
                  Content="&#xee00;" />
                <ComboBox
                  x:Name="PART_ComboFilterPresets"
                  DockPanel.Dock="Left"
                  VerticalAlignment="Center" />
              </DockPanel>
              <ScrollViewer
                DockPanel.Dock="Top"
                Padding="0,0,0,15"
                HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PART_PanelItemsHost" />
              </ScrollViewer>
            </DockPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <DataTemplate x:Key="TopPanelGeneralViewSettingsTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xefe2;"
      FontFamily="{StaticResource FontIcoFont}"
      FontSize="18" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelFilterPresetsSelectionTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xeec0;"
      FontFamily="{StaticResource FontIcoFont}"
      FontSize="20" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelGroupSettingsTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xee03;"
      FontFamily="{StaticResource FontIcoFont}"
      FontSize="20" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelSortSettingsTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xefee;"
      FontFamily="{StaticResource FontIcoFont}"
      FontSize="20" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelSwitchDetailsViewTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xE145;"
      FontFamily="Segoe UI Symbol" FontSize="20" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelSwitchGridViewTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xE138;"
      FontFamily="Segoe UI Symbol" FontSize="20" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelSwitchListViewTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xE14C;"
      FontFamily="Segoe UI Symbol" FontSize="20" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelUpdateButtonTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xef08;"
      FontFamily="{StaticResource FontIcoFont}"
      FontSize="24"
      Foreground="{DynamicResource WarningBrush}" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelExplorerSwitchTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xeeed;"
      FontFamily="{StaticResource FontIcoFont}"
      FontSize="20" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelSelectRandomGameButtonTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xef03;"
      FontFamily="{StaticResource FontIcoFont}"
      FontSize="20" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelViewSelectRandomGameButtonTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xefcf;"
      FontFamily="{StaticResource FontIcoFont}"
      FontSize="20" />
  </DataTemplate>

  <DataTemplate x:Key="TopPanelSearchButtonTemplate">
    <TextBlock
      HorizontalAlignment="Center" VerticalAlignment="Center"
      Text="&#xed12;"
      FontFamily="{StaticResource FontIcoFont}"
      FontSize="20" />
  </DataTemplate>

  <Style x:Key="TopPanelMenu" TargetType="{x:Type ContextMenu}">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Background" Value="{DynamicResource PopupBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PopupBorderBrush}" />
    <Setter Property="BorderThickness" Value="{DynamicResource PopupBorderThickness}" />
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Margin" Value="15" />
    <Setter Property="Effect" Value="{DynamicResource DefaultDropShadow}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ContextMenu}">
          <Border
            Padding="10"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{StaticResource ControlCornerRadius}"
            Grid.IsSharedSizeScope="True">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
              <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
            </ScrollViewer>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="TopPanelFilterToggle" TargetType="CheckBox">
    <Setter Property="MinWidth" Value="35" />
    <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Margin" Value="10,6,0,6" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrushDarker}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type CheckBox}">
          <Border
            Background="{TemplateBinding Background}"
            BorderThickness="0" CornerRadius="3">
            <StackPanel Margin="6,0,6,0" Orientation="Horizontal">
              <TextBlock
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Text="&#xef29;"
                FontFamily="{StaticResource FontIcoFont}"
                FontSize="20"
                Foreground="{TemplateBinding Foreground}" />
              <TextBlock
                Style="{StaticResource BaseTextBlockStyle}"
                Margin="3,0,0,0" VerticalAlignment="Center"
                Text="{StaticResource LOCFilterActiveLabel}"
                Foreground="{TemplateBinding Foreground}"
                Name="TextFilter" />
            </StackPanel>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="Tag" Value="{StaticResource True}">
              <Setter Property="Visibility" TargetName="TextFilter" Value="Visible" />
              <Setter Property="Background" Value="{DynamicResource NormalBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{StaticResource False}">
              <Setter Property="Visibility" TargetName="TextFilter" Value="Collapsed" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="TopPanelNotificationsToggle" TargetType="ToggleButton">
    <Setter Property="Margin" Value="10,6,0,6" />
    <Setter Property="MinWidth" Value="35" />
    <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ToggleButton}">
          <Border Background="Transparent">
            <Grid>
              <TextBlock
                HorizontalAlignment="Center"
                Text="&#xeea3;"
                FontFamily="{StaticResource FontIcoFont}"
                FontSize="24"
                Foreground="{TemplateBinding Foreground}" />
              <Border
                Width="15" Height="15"
                Margin="20,0,0,0" HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="OrangeRed" CornerRadius="3">
                <TextBlock
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Text="{Api Notifications.Count}"
                  FontSize="12"
                  Foreground="{DynamicResource TextBrushDark}" />
              </Border>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <DataTrigger Binding="{Api Notifications.Count}" Value="0">
        <Setter Property="Visibility" Value="Collapsed" />
      </DataTrigger>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Foreground" Value="{DynamicResource TextBrushDarker}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="{x:Type TopPanel}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type TopPanel}">
          <Border
            Height="50"
            Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource PanelSeparatorBrush}"
            BorderThickness="0,0,0,1">
            <DockPanel Margin="0,3,110,3">
              <Border
                x:Name="PART_ElemMainMenu"
                DockPanel.Dock="Left"
                Margin="5,0,0,0"
                Background="Transparent" Cursor="Hand"
                WindowChrome.IsHitTestVisibleInChrome="True">
                <Image
                  Height="40"
                  Margin="10,0,5,0"
                  RenderOptions.BitmapScalingMode="Fant"
                  Source="{ThemeFile 'Images/applogo.png'}" />
              </Border>

              <SearchBox
                x:Name="PART_TextMainSearch"
                DockPanel.Dock="Left"
                Width="300"
                Margin="5,6,0,6"
                WindowChrome.IsHitTestVisibleInChrome="True" />

              <StackPanel
                x:Name="PART_PanelMainItems"
                DockPanel.Dock="Left"
                Margin="0,6,0,6" VerticalAlignment="Stretch"
                Orientation="Horizontal" />

              <CheckBox
                x:Name="PART_ToggleFilter"
                Style="{DynamicResource TopPanelFilterToggle}"
                DockPanel.Dock="Left"
                ToolTip="{StaticResource LOCFilters}" />

              <ToggleButton
                x:Name="PART_ToggleNotifications"
                Style="{DynamicResource TopPanelNotificationsToggle}"
                DockPanel.Dock="Left" />

              <StackPanel
                x:Name="PART_PanelMainPluginItems"
                DockPanel.Dock="{Settings PluginTopPanelAlignment}"
                Margin="15,6,15,6" VerticalAlignment="Stretch"
                Orientation="Horizontal" />

              <StackPanel
                DockPanel.Dock="Left"
                Margin="0,5,0,5" HorizontalAlignment="Center"
                Orientation="Horizontal">
                <Grid MinWidth="300" MaxWidth="600">
                  <ProgressBar Name="PART_ProgressGlobal" />
                  <TextBlock
                    Style="{StaticResource BaseTextBlockStyle}"
                    Margin="5,0,5,0" HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Name="PART_TextProgressText" />
                </Grid>

                <Button
                  Margin="5,0,0,0"
                  Content="{StaticResource LOCCancelLabel}"
                  Name="PART_ButtonProgressCancel" WindowChrome.IsHitTestVisibleInChrome="True" />
              </StackPanel>
            </DockPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

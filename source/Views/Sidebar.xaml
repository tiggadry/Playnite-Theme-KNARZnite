<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style TargetType="{x:Type Sidebar}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Sidebar}">
          <Border
            x:Name="BorderContentHolder"
            Margin="{TemplateBinding Padding}"
            Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource PanelSeparatorBrush}"
            BorderThickness="0,0,1,0">
            <DockPanel x:Name="DockContentHolder">
              <Border
                x:Name="PART_ElemMainMenu"
                DockPanel.Dock="Top"
                Width="44" Height="44"
                Margin="0,0,0,5" Padding="5"
                Background="Transparent" Cursor="Hand"
                WindowChrome.IsHitTestVisibleInChrome="True">
                <Image RenderOptions.BitmapScalingMode="Fant" Source="{ThemeFile 'Images/applogo.png'}" />
              </Border>

              <ScrollViewer
                x:Name="ScrollSidebarItems"
                DockPanel.Dock="Top"
                CanContentScroll="True" HorizontalScrollBarVisibility="Hidden"
                VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PART_PanelSideBarItems" Orientation="Vertical" />
              </ScrollViewer>            
            </DockPanel>
          </Border>
          <ControlTemplate.Triggers>
            <DataTrigger Binding="{Settings SidebarPosition}" Value="Right">
              <Setter Property="Padding" Value="0,25,0,0" />
              <Setter Property="Margin" TargetName="PART_ElemMainMenu" Value="0,0,0,5" />
              <Setter Property="BorderThickness" TargetName="BorderContentHolder" Value="1,0,0,0" />
            </DataTrigger>
            <DataTrigger Binding="{Settings SidebarPosition}" Value="Top">
              <Setter Property="Margin" TargetName="PART_ElemMainMenu" Value="0,0,5,0" />
              <Setter Property="BorderThickness" TargetName="BorderContentHolder" Value="0,0,0,1" />
              <Setter Property="DockPanel.Dock" TargetName="PART_ElemMainMenu" Value="Left" />
              <Setter Property="DockPanel.Dock" TargetName="ScrollSidebarItems" Value="Left" />
              <Setter Property="Margin" TargetName="ScrollSidebarItems" Value="0,0,100,0" />
              <Setter Property="Orientation" TargetName="PART_PanelSideBarItems" Value="Horizontal" />
            </DataTrigger>
            <DataTrigger Binding="{Settings SidebarPosition}" Value="Bottom">
              <Setter Property="Margin" TargetName="PART_ElemMainMenu" Value="0,0,5,0" />
              <Setter Property="BorderThickness" TargetName="BorderContentHolder" Value="0,1,0,0" />
              <Setter Property="DockPanel.Dock" TargetName="PART_ElemMainMenu" Value="Left" />
              <Setter Property="DockPanel.Dock" TargetName="ScrollSidebarItems" Value="Left" />
              <Setter Property="Orientation" TargetName="PART_PanelSideBarItems" Value="Horizontal" />
            </DataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style TargetType="{x:Type MainWindow}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type MainWindow}">
          <Border
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition />
              </Grid.ColumnDefinitions>
              <Grid.Resources>
                <Storyboard x:Key="VisibilityOn">
                  <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="PART_Notifications" Storyboard.TargetProperty="Margin">
                    <SplineThicknessKeyFrame KeyTime="00:00:00" Value="-260,0,0,0" />
                    <SplineThicknessKeyFrame KeyTime="0:0:0.10" Value="0,0,0,0" />
                  </ThicknessAnimationUsingKeyFrames>
                </Storyboard>
                <Storyboard x:Key="VisibilityOff">
                  <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="PART_Notifications" Storyboard.TargetProperty="Margin">
                    <SplineThicknessKeyFrame KeyTime="00:00:00" Value="0,0,0,0" />
                    <SplineThicknessKeyFrame KeyTime="0:0:0.10" Value="-260,0,0,0" />
                  </ThicknessAnimationUsingKeyFrames>
                </Storyboard>
              </Grid.Resources>

              <DockPanel>
                <Sidebar
                  x:Name="PART_Sidebar"
                  DockPanel.Dock="{Settings SidebarPosition}"
                  Effect="{DynamicResource DefaultDropShadow}"
                  Panel.ZIndex="999" />

                <ContentControl DockPanel.Dock="Top" Name="PART_ContentView" />
              </DockPanel>
              <NotificationPanel
                x:Name="PART_Notifications"
                Grid.Row="0" Grid.Column="0"
                Grid.RowSpan="2"
                Width="260"
                HorizontalAlignment="Left" VerticalAlignment="Stretch"
                AnimatedVisibility.Collapsed="{StaticResource VisibilityOff}"
                AnimatedVisibility.Visibility="{Settings NotificationPanelVisible}"
                AnimatedVisibility.Visible="{StaticResource VisibilityOn}"
                Effect="{DynamicResource DefaultDropShadow}"
                WindowChrome.IsHitTestVisibleInChrome="True" />
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

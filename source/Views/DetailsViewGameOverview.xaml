                          Header="{DynamicResource LOCGameRelations_SimilarGamesLabel}"
                          IsExpanded="True">
                          <ContentControl x:Name="GameRelations_SimilarGamesControl" Margin="0,10,0,0" />
                        </Expander>

                        <Expander
                          x:Name="Panel_GameRelations_SameSeriesControl"
                          Margin="0,0,0,10"
                          Visibility="{PluginSettings Plugin=GameRelations,
                                                      Path=SameSeriesControlSettings.IsVisible,
                                                      Converter={StaticResource BooleanToVisibilityConverter},
                                                      FallbackValue=Collapsed}"
                          Header="{DynamicResource LOCGameRelations_SameSeriesLabel}"
                          IsExpanded="True">
                          <ContentControl x:Name="GameRelations_SameSeriesControl" Margin="0,10,0,0" />
                        </Expander>

                        <Expander
                          x:Name="Panel_GameRelations_SameDeveloperControl"
                          Margin="0,0,0,10"
                          Visibility="{PluginSettings Plugin=GameRelations,
                                                      Path=SameDeveloperControlSettings.IsVisible,
                                                      Converter={StaticResource BooleanToVisibilityConverter},
                                                      FallbackValue=Collapsed}"
                          Header="{DynamicResource LOCGameRelations_SameDeveloperLabel}"
                          IsExpanded="True">
                          <ContentControl x:Name="GameRelations_SameDeveloperControl" Margin="0,10,0,0" />
                        </Expander>

                        <Expander
                          x:Name="Panel_GameRelations_SamePublisherControl"
                          Margin="0,0,0,10"
                          Visibility="{PluginSettings Plugin=GameRelations,
                                                      Path=SamePublisherControlSettings.IsVisible,
                                                      Converter={StaticResource BooleanToVisibilityConverter},
                                                      FallbackValue=Collapsed}"
                          Header="{DynamicResource LOCGameRelations_SamePublisherLabel}"
                          IsExpanded="True">
                          <ContentControl x:Name="GameRelations_SamePublisherControl" Margin="0,0,0,0" />
                        </Expander>
                      </StackPanel>
                    </TabItem>
                    <!--#region WebExplorer-->
                    <TabItem Visibility="{Binding ElementName=WebExplorer_BrowserHostViewControl, Path=Content.IsControlVisible, Converter={StaticResource BooleanToVisibilityConverter}, TargetNullValue=Collapsed, FallbackValue=Collapsed}">
                      <TabItem.Header>
                        <TextBlock Style="{DynamicResource DetailsViewTabHeaderStyle}" Text="{DynamicResource LOCWebExplorer_WebLabel}" />
                      </TabItem.Header>
                      <StackPanel
                        Margin="0,-25,0,15"
                        Background="{TemplateBinding Background}"
                        Orientation="Vertical">
                        <ContentControl
                          x:Name="WebExplorer_BrowserHostViewControl"
                          Height="{DynamicResource WebExplorerControlHeight}"
                          VerticalAlignment="Top" />
                      </StackPanel>
                    </TabItem>
                    <!--#endregion-->
                  </TabControl>
                </DockPanel>
              </Grid>
            </Grid>
          </ScrollViewer>
          <ControlTemplate.Triggers>
            <MultiDataTrigger>
              <MultiDataTrigger.Conditions>
                <Condition Binding="{Binding Tag, ElementName=PART_TextDisplayName}" Value="{StaticResource True}" />
                <Condition Binding="{Binding ElementName=ExtraMetadataLoader_LogoLoaderControl, Path=Visibility, FallbackValue=Collapsed}" Value="Visible" />
                <Condition Binding="{PluginSettings Plugin=ExtraMetadataLoader, Path=IsLogoAvailable, FallbackValue=False}" Value="True" />
              </MultiDataTrigger.Conditions>
              <Setter Property="Visibility" TargetName="TitleIconPanel" Value="Collapsed" />
              <Setter Property="Margin" TargetName="ExtraMetadataLoader_LogoLoaderControl" Value="0" />
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding Tag, ElementName=ButtonBar}" Value="{StaticResource False}">
              <Setter Property="Background" TargetName="LinkBar" Value="Transparent" />
              <Setter Property="Effect" TargetName="LinkBar" Value="{DynamicResource NoDropShadow}" />
              <Setter Property="BorderThickness" TargetName="LinkBar" Value="0" />
              <Setter Property="Padding" TargetName="LinkBar" Value="0" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, ElementName=DetailsSection}" Value="{StaticResource True}">
              <Setter Property="Visibility" TargetName="DetailsSection" Value="Collapsed" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, ElementName=PlayTimeButton}" Value="{StaticResource False}">
              <Setter Property="Visibility" TargetName="PlayTimeButton" Value="Collapsed" />
            </DataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

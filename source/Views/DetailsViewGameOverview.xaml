<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style TargetType="{x:Type DetailsViewGameOverview}">
    <Style.Resources>
      <TextBlock
        x:Key="DefaultLinkTextBlock"
        Style="{StaticResource BaseTextBlockStyle}"
        Text="{DynamicResource DefaultLinkIcon}"
        FontFamily="{DynamicResource FontIcoFont}" />
    </Style.Resources>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type DetailsViewGameOverview}">
          <ScrollViewer
            x:Name="PART_ScrollViewHost"
            Style="{DynamicResource DetailsScrollViewer}"
            HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>
              <Grid x:Name="TopGrid">
                <Grid.ContextMenu>
                  <ContextMenu Visibility="{PluginStatus Plugin=felixkmh_Extras_Plugin, Path=IsInstalled}" IsOpen="{PluginSettings Plugin=ThemeExtras, Path=Menus.IsOpen, Mode=OneWayToSource, FallbackValue={StaticResource False}}">
                    <MenuItem
                      Visibility="{PluginStatus Plugin=ExtraMetadataLoader_705fdbca-e1fc-4004-b839-1d040b8b4429,
                                                Path=IsInstalled}"
                      ItemsSource="{PluginSettings Plugin=ThemeExtras,
                                                   Path=Menus.EMLGameMenuItems,
                                                   FallbackValue={x:Null}}"
                      Header="ExtraMetadataLoader" />
                    <MenuItem
                      Visibility="{PluginStatus Plugin=playnite-backgroundchanger-plugin,
                                                Path=IsInstalled}"
                      ItemsSource="{PluginSettings Plugin=ThemeExtras,
                                                   Path=Menus.BackgroundChangerGameMenuItems,
                                                   FallbackValue={x:Null}}"
                      Header="BackgroundChanger" />
                    <MenuItem
                      Visibility="{PluginStatus Plugin=UniPlaySong.a1b2c3d4-e5f6-7890-abcd-ef1234567890,
                                                Path=IsInstalled}"
                      ItemsSource="{PluginSettings Plugin=ThemeExtras,
                                                   Path=Menus.UniPlaySongGameMenuItems,
                                                   FallbackValue={x:Null}}"
                      Header="UniPlaySong" />
                    <MenuItem
                      Visibility="{PluginStatus Plugin=playnite-screenshotsvisualizer-plugin,
                                                Path=IsInstalled}"
                      ItemsSource="{PluginSettings Plugin=ThemeExtras,
                                                   Path=Menus.ScreenshotsVisualizerGameMenuItems,
                                                   FallbackValue={x:Null}}"
                      Header="ScreenshotsVisualizer" />
                    <Separator />
                    <MenuItem Command="{PluginSettings Plugin=ThemeExtras, Path=Commands.OpenGameAssetFolderCommand, FallbackValue={x:Null}}" Header="Open Metadata Folder" />
                    <MenuItem
                      Visibility="{PluginStatus Plugin=ExtraMetadataLoader_705fdbca-e1fc-4004-b839-1d040b8b4429,
                                                Path=IsInstalled}"
                      Command="{PluginSettings Plugin=ThemeExtras,
                                               Path=Commands.OpenExtraMetadataFolderCommand,
                                               FallbackValue={x:Null}}"
                      CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DetailsViewGameOverview}}"
                      Header="Open Extra Metadata Folder" />
                    <MenuItem
                      Visibility="{PluginStatus Plugin=UniPlaySong.a1b2c3d4-e5f6-7890-abcd-ef1234567890,
                                                Path=IsInstalled}"
                      Command="{PluginSettings Plugin=ThemeExtras,
                                               Path=Commands.OpenMusicFolderCommand,
                                               FallbackValue={x:Null}}"
                      CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DetailsViewGameOverview}}"
                      Header="Open Music Folder" />
                    <MenuItem
                      Visibility="{PluginStatus Plugin=playnite-backgroundchanger-plugin,
                                                Path=IsInstalled}"
                      Command="{PluginSettings Plugin=ThemeExtras,
                                               Path=Commands.OpenBackgroundChangerMetadataFolderCommand,
                                               FallbackValue={x:Null}}"
                      CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DetailsViewGameOverview}}"
                      Header="Open BackgroundChanger Folder" />
                    <MenuItem
                      Visibility="{PluginStatus Plugin=playnite-screenshotsvisualizer-plugin,
                                                Path=IsInstalled}"
                      Command="{PluginSettings Plugin=ThemeExtras,
                                               Path=Commands.OpenScreenshotsFolderCommand,
                                               FallbackValue={x:Null}}"
                      CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DetailsViewGameOverview}}"
                      Header="Open Screenshots Folders" />
                    <Separator />
                    <MenuItem
                      Command="{PluginSettings Plugin=ThemeExtras,
                                               Path=Commands.OpenGameInstallLocationCommand,
                                               FallbackValue={x:Null}}"
                      CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DetailsViewGameOverview}}"
                      Header="Open Install Folder" />
                    <MenuItem
                      Visibility="{PluginStatus Plugin=SaveFileView_f68f302b-9799-4b77-a982-4bfca97130e2,
                                                Path=IsInstalled}"
                      Command="{PluginSettings Plugin=ThemeExtras,
                                               Path=Commands.OpenGameSaveDirectoriesCommand,
                                               FallbackValue={x:Null}}"
                      CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DetailsViewGameOverview}}"
                      Header="Open Save Folder" />
                    <MenuItem
                      Visibility="{PluginStatus Plugin=SaveFileView_f68f302b-9799-4b77-a982-4bfca97130e2,
                                                Path=IsInstalled}"
                      Command="{PluginSettings Plugin=ThemeExtras,
                                               Path=Commands.OpenGameConfigDirectoriesCommand,
                                               FallbackValue={x:Null}}"
                      CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DetailsViewGameOverview}}"
                      Header="Open Config Folder" />
                  </ContextMenu>
                </Grid.ContextMenu>

                <Grid
                  x:Name="BackgroundImageGrid"
                  HorizontalAlignment="Center" VerticalAlignment="Top">
                  <Grid.Style>
                    <Style TargetType="Grid">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=BackgroundChanger, Path=Visibility}" Value="Visible">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{PluginSettings Plugin=BackgroundChanger, Path=EnableBackgroundImage, FallbackValue=False}" Value="False">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Grid.Style>
                  <FadeImage
                    x:Name="PART_ImageBackground"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Stretch="Uniform">
                    <FadeImage.ImageOpacityMask>
                      <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,0" RadiusX="2" RadiusY="0.9">
                        <RadialGradientBrush.GradientStops>
                          <GradientStop Color="Black" Offset="0.3" />
                          <GradientStop Color="Transparent" Offset="1" />
                        </RadialGradientBrush.GradientStops>
                      </RadialGradientBrush>
                    </FadeImage.ImageOpacityMask>
                  </FadeImage>
                </Grid>

                <Grid
                  x:Name="BackgroundChanger"
                  HorizontalAlignment="Center" VerticalAlignment="Top">
                  <Grid.Style>
                    <Style TargetType="Grid">
                      <Style.Triggers>
                        <DataTrigger Binding="{PluginSettings Plugin=BackgroundChanger, Path=EnableBackgroundImage, FallbackValue=False}" Value="False">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{PluginSettings Plugin=BackgroundChanger, Path=HasDataBackground, FallbackValue=False}" Value="False">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Grid.Style>
                  <FadeImage
                    x:Name="ImageBackgroundChanger"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Stretch="Uniform">
                    <FadeImage.Source>
                      <PriorityBinding>
                        <Binding ElementName="BackgroundChanger_PluginBackgroundImage" Path="Content.Source" />
                        <Binding ElementName="PART_ImageBackground" Path="Source" />
                      </PriorityBinding>
                    </FadeImage.Source>
                    <FadeImage.ImageOpacityMask>
                      <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,0" RadiusX="2" RadiusY="0.9">
                        <RadialGradientBrush.GradientStops>
                          <GradientStop Color="Black" Offset="0.3" />
                          <GradientStop Color="Transparent" Offset="1" />
                        </RadialGradientBrush.GradientStops>
                      </RadialGradientBrush>
                    </FadeImage.ImageOpacityMask>
                  </FadeImage>
                </Grid>

                <!--  #Source Icon Visible  -->
                <!--
                  Selector1 host for DuplicateHider custom element (SourceSelector1 / Style1).
                  This container is shown only when the selector has content.
                  Per-icon visuals are resolved through DuplicateHider_IconContentControlStyle1
                  (defined in DerivedStyles/GridViewItemTemplate.xaml).
                  Shared color/overlay resources used by that style come from Constants(.red).xaml.
                  DuplicateHiderSourceIconEffect adds a host-level shadow around the icon strip.
                -->
                <Grid
                  Height="58"
                  HorizontalAlignment="Left" VerticalAlignment="Top">
                  <Grid.Style>
                    <Style TargetType="Grid">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=DuplicateHider_SourceSelector1, Path=HasContent}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Grid.Style>
                  <Border Margin="10" Background="Transparent">
                    <ContentControl x:Name="DuplicateHider_SourceSelector1" Effect="{DynamicResource DuplicateHiderSourceIconEffect}" />
                  </Border>
                </Grid>
                <ContentControl
                  x:Name="BackgroundChanger_PluginBackgroundImage"
                  HorizontalAlignment="Center" VerticalAlignment="Top"
                  Visibility="Collapsed" />
              </Grid>

              <Grid Margin="20,0,20,0" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                  <RowDefinition Height="{Settings CalculatedGameDetailsIndentation}" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Age Ratings  -->
                <Grid Grid.Row="0" MaxWidth="{DynamicResource DetailsViewDetailsMaxWidth}">
                  <ItemsControl
                    x:Name="AgeRating"
                    Margin="0,0,0,0" HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Visibility="{DynamicResource DE_ShowAgeRating}"
                    IsEnabled="False"
                    ItemsSource="{Binding Game.AgeRatings}"
                    IsTabStop="False">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Height="Auto" Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                          </Grid.ColumnDefinitions>
                          <Border
                            x:Name="RatingIcon"
                            Width="Auto" Height="64"
                            Margin="1" HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Visible"
                            Background="White" BorderThickness="2"
                            CornerRadius="5">
                            <Image
                              x:Name="RatingIconImage"
                              Grid.Column="0"
                              Margin="3"
                              RenderOptions.BitmapScalingMode="Fant" SnapsToDevicePixels="True"
                              Source="{ThemeFileBinding Name,
                                                        PathFormat=Images/AgeRatings/\{0\}.png}" />
                          </Border>
                        </Grid>
                        <DataTemplate.Triggers>
                          <DataTrigger Binding="{Binding Source, ElementName=RatingIconImage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                        </DataTemplate.Triggers>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>

                <Grid Grid.Row="1" MaxWidth="{DynamicResource DetailsViewDetailsMaxWidth}">
                  <!--#region Logo & Cover Image-->
                  <Border
                    x:Name="ExtraMetadataLoader_LogoLoaderControlGrid"
                    MinHeight="{PluginSettings Plugin=ExtraMetadataLoader,
                                               Path=LogoMaxHeight,
                                               FallbackValue=0}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Tag="{DynamicResource DetailsViewAllowUseOfLogos}">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                          <DataTrigger Binding="{PluginSettings Plugin=ExtraMetadataLoader, Path=EnableLogos, FallbackValue=False}" Value="false">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}, FallbackValue=False}" Value="false">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                          <DataTrigger Binding="{PluginSettings Plugin=ExtraMetadataLoader, Path=EnableLogos, FallbackValue=False}" Value="false">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <ContentControl x:Name="ExtraMetadataLoader_LogoLoaderControl" Margin="0,0,0,70" />
                  </Border>

                  <DockPanel
                    x:Name="TitleIconPanel"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom">
                    <Image
                      DockPanel.Dock="Left"
                      MaxWidth="48" MaxHeight="48"
                      Margin="0,0,10,0" VerticalAlignment="Center"
                      Name="PART_ImageIcon" RenderOptions.BitmapScalingMode="Fant" />
                    <TextBlock
                      DockPanel.Dock="Left"
                      Margin="0,0,10,0" VerticalAlignment="Center"
                      Tag="{DynamicResource DetailsViewHideGameNameIfLogoVisible}"
                      FontFamily="{DynamicResource FontFamily}"
                      FontSize="{DynamicResource FontSizeLargest}"
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource TextBrush}"
                      Name="PART_TextDisplayName" TextWrapping="Wrap">
                      <TextBlock.Effect>
                        <DropShadowEffect RenderingBias="Quality" ShadowDepth="2" />
                      </TextBlock.Effect>
                    </TextBlock>
                  </DockPanel>

                  <DockPanel
                    x:Name="CoverDockPanel"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Visibility="{Binding CoverVisibility}"
                    Effect="{DynamicResource DefaultDropShadow}">
                    <ContentControl
                      x:Name="ThemeExtras_Banner"
                      DockPanel.Dock="Top"
                      Width="{Binding ActualWidth, ElementName=PART_ImageCover}"
                      Visibility="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Tag="{DynamicResource DetailsViewCoverDisplayLibraryBanner}"
                      RenderOptions.BitmapScalingMode="Fant" />
                    <Grid x:Name="CoverGrid" DockPanel.Dock="Top">
                      <Image
                        Height="{Settings GameDetailsCoverHeight}"
                        Visibility="{Binding IsVisible, ElementName=BackgroundChanger_PluginBackgroundImage, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                        Name="PART_ImageCover" RenderOptions.BitmapScalingMode="Fant"
                        Stretch="Uniform" StretchDirection="Both" />
                      <ContentControl
                        x:Name="BackgroundChanger_PluginCoverImage"
                        DockPanel.Dock="Right"
                        Height="{Settings GameDetailsCoverHeight}"
                        VerticalAlignment="Bottom"
                        Visibility="{PluginSettings Plugin=BackgroundChanger,
                                                    Path=HasDataCover,
                                                    FallbackValue={x:Static Visibility.Collapsed},
                                                    Converter={StaticResource BooleanToVisibilityConverter}}"
                        RenderOptions.BitmapScalingMode="Fant" />
                    </Grid>
                  </DockPanel>
                  <!--#regionend-->
                </Grid>
                <DockPanel
                  x:Name="ButtonBar"
                  Grid.Row="2"
                  MaxWidth="{DynamicResource DetailsViewDetailsMaxWidth}"
                  Margin="0,20,0,15"
                  Tag="{DynamicResource LinkBarAsBox}"
                  Background="Transparent">
                  <StackPanel DockPanel.Dock="Left" VerticalAlignment="Bottom">
                    <WrapPanel Margin="0,15,0,0" Orientation="Horizontal">
                      <Button
                        x:Name="ButtonPlayAction"
                        Style="{DynamicResource PlayButton}"
                        VerticalAlignment="Center"
                        Command="{Binding ContextActionCommand}"
                        ToolTip="{Binding ContextActionDescription}" />
                      <Button
                        x:Name="ButtonInstallAction"
                        Style="{DynamicResource InstallButton}"
                        VerticalAlignment="Center"
                        Command="{Binding ContextActionCommand}"
                        ToolTip="{Binding ContextActionDescription}"
                        Tag="{DynamicResource HidePlayButtonForManualGames}" />
                      <Button
                        x:Name="ButtonContextAction"
                        Style="{DynamicResource ContextActionButton}"
                        VerticalAlignment="Center"
                        Command="{Binding ContextActionCommand}"
                        ToolTip="{Binding ContextActionDescription}" />
                      <Button
                        x:Name="PART_ButtonEditGame"
                        Width="40" Height="40"
                        Margin="0,0,10,0" VerticalAlignment="Center"
                        Content="&#xEDED;"
                        FontFamily="{DynamicResource FontIcoFont}" />
                      <Button
                        x:Name="PART_ButtonMoreActions"
                        Width="40" Height="40"
                        Margin="0,0,10,0" VerticalAlignment="Center"
                        Content="&#xEFA2;"
                        FontFamily="{DynamicResource FontIcoFont}" />

                      <Border
                        x:Name="PlayTimeButton"
                        Style="{StaticResource BorderBlock}"
                        Height="40"
                        Margin="0,0,10,0" Padding="8,0"
                        Tag="{DynamicResource ShowPlayTimeInButtonBar}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                          <TextBlock
                            Style="{DynamicResource BaseTextBlockStyle}"
                            Margin="0,0,10,0" VerticalAlignment="Center"
                            Text="&#xEEDC;"
                            FontFamily="{StaticResource FontIcoFont}"
                            FontSize="24"
                            Foreground="{DynamicResource GlyphBrush}" />
                          <StackPanel VerticalAlignment="Center">
                            <TextBlock
                              Style="{DynamicResource BaseTextBlockStyle}"
                              Text="{DynamicResource LOCTimePlayed}"
                              FontSize="{DynamicResource FontSizeSmall}" />
                            <TextBlock
                              Style="{DynamicResource BaseTextBlockStyle}"
                              Text="{Binding Game.Playtime, Converter={StaticResource PlayTimeToStringConverter}}"
                              FontSize="{DynamicResource FontSizeSmall}" />
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <ContentControl
                        x:Name="ScreenshotUtilities_ButtonControl"
                        Style="{DynamicResource ActionControl}"
                        Visibility="{PluginSettings Plugin=ScreenshotUtilities,
                                                    Path=IsButtonControlVisible,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />
                      <ContentControl
                        x:Name="PlayState_GameStateSwitchControl"
                        Style="{DynamicResource ActionControl}"
                        Visibility="{PluginSettings Plugin=PlayState,
                                                    Path=IsControlVisible,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />
                      <ContentControl
                        x:Name="ScreenshotsVisualizer_PluginButton"
                        Style="{DynamicResource ActionControl}"
                        Visibility="{PluginSettings Plugin=ScreenshotsVisualizer,
                                                    Path=HasData,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />
                      <ContentControl
                        x:Name="HowLongToBeat_PluginButton"
                        Style="{DynamicResource ActionControl}"
                        Visibility="{PluginSettings Plugin=HowLongToBeat,
                                                    Path=EnableIntegrationButton,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />

                      <StackPanel Margin="0,0,10,0" VerticalAlignment="Center">
                        <StackPanel.Style>
                          <Style TargetType="{x:Type StackPanel}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                              <DataTrigger Binding="{PluginSettings Plugin=HowLongToBeat, Path=HasData, FallbackValue=False}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <ContentControl
                          x:Name="HowLongToBeat_PluginProgressBar"
                          Width="250" Height="40" />
                      </StackPanel>

                      <ContentControl
                        x:Name="CheckDlc_PluginButton"
                        Style="{DynamicResource ActionControl}"
                        Visibility="{PluginSettings Plugin=CheckDlc,
                                                    Path=EnableIntegrationButton,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />
                      <ContentControl
                        x:Name="SuccessStory_PluginButton"
                        Style="{DynamicResource ActionControl}"
                        Visibility="{PluginSettings Plugin=SuccessStory,
                                                    Path=HasData,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />
                      <ContentControl
                        x:Name="PlayniteAchievements_PluginButton"
                        Style="{DynamicResource ActionControl}"
                        Visibility="{PluginSettings Plugin=PlayniteAchievements,
                                                    Path=HasData,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />
                      <ContentControl
                        x:Name="GameActivity_PluginButton"
                        Style="{DynamicResource ActionControl}"
                        Visibility="{PluginSettings Plugin=GameActivity,
                                                    Path=HasData,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />
                      <ContentControl
                        x:Name="SystemChecker_PluginButton"
                        Style="{DynamicResource ActionControl}"
                        Visibility="{PluginSettings Plugin=SystemChecker,
                                                    Path=EnableIntegrationButton,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />
                      <ContentControl
                        x:Name="CheckLocalizations_PluginButton"
                        Style="{DynamicResource ActionControl}"
                        Visibility="{PluginSettings Plugin=CheckLocalizations,
                                                    Path=EnableIntegrationButton,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />
                      <ContentControl x:Name="NewsViewer_PlayersInGameViewerControl">
                        <ContentControl.Resources>
                          <Style BasedOn="{StaticResource PlayersCountButtonStyle}" TargetType="Button" />
                        </ContentControl.Resources>
                      </ContentControl>

                      <ContentControl
                        x:Name="LibraryManagement_PluginFeaturesIconList"
                        Height="35"
                        VerticalAlignment="Center"
                        Visibility="{PluginSettings Plugin=LibraryManagement,
                                                    Path=EnableIntegrationFeatures,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}"
                        Opacity="0.85" />

                      <ContentControl
                        x:Name="GogSecondClassWatcher_SecondClassWatcherControl"
                        Margin="5,0,0,0" VerticalAlignment="Center"
                        Visibility="{PluginSettings Plugin=GogSecondClassWatcher,
                                                    Path=IsControlVisible,
                                                    FallbackValue=Collapsed,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </WrapPanel>

                    <Border
                      x:Name="LinkBar"
                      Margin="0,20,0,0" Padding="5"
                      Tag="{DynamicResource DisplayLinkBar}"
                      Background="{DynamicResource OpaqueButtonBackgroundBrush}"
                      BorderBrush="{DynamicResource NormalBorderBrush}"
                      BorderThickness="{StaticResource ControlBorderThickness}"
                      CornerRadius="{StaticResource ControlCornerRadius}"
                      Effect="{DynamicResource DefaultSubtleDropShadow}">
                      <Border.Style>
                        <Style TargetType="{x:Type Border}">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}, FallbackValue=True}" Value="True">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <DockPanel>
                        <TextBlock
                          Margin="10,5,20,5" VerticalAlignment="Center"
                          Text="&#xef71;"
                          FontFamily="{StaticResource FontIcoFont}"
                          FontSize="40"
                          Foreground="{DynamicResource GlyphBrush}" />
                        <ItemsControl DockPanel.Dock="Left" ItemsSource="{Binding Game.Links}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <WrapPanel VerticalAlignment="Center" Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type Link}">
                              <TextBlock
                                DockPanel.Dock="Left"
                                Margin="0,4,10,4"
                                Typography.Capitals="AllSmallCaps">
                                <Hyperlink Command="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.OpenLinkCommand}" CommandParameter="{Binding}">
                                  <Run Text="{Binding Name}" />
                                </Hyperlink>
                              </TextBlock>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </DockPanel>
                    </Border>
                  </StackPanel>
                </DockPanel>

                <DockPanel
                  x:Name="DetailsSection"
                  Grid.Row="3"
                  MaxWidth="{DynamicResource DetailsViewDetailsMaxWidth}"
                  Tag="{DynamicResource DisableDetailsSection}">
                  <StackPanel
                    DockPanel.Dock="Left"
                    Width="420"
                    Margin="0,0,10,0">
                    <StackPanel.Resources>
                      <Style TargetType="ItemsControl">
                        <Setter Property="VerticalAlignment" Value="Center" />
                      </Style>
                      <Style BasedOn="{StaticResource {x:Type Label}}" TargetType="Label">
                        <Setter Property="Margin" Value="0,4,8,4" />
                        <Setter Property="VerticalAlignment" Value="Top" />
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                      </Style>
                      <Style BasedOn="{StaticResource PropertyItemButton}" TargetType="Button">
                        <Setter Property="VerticalAlignment" Value="Center" />
                      </Style>
                    </StackPanel.Resources>

                    <TextBlock
                      Style="{DynamicResource BaseTextBlockStyle}"
                      Margin="5,14,5,2"
                      Text="{DynamicResource LOCGameDetails}"
                      FontSize="{DynamicResource FontSizeLarger}"
                      FontWeight="Bold"
                      Foreground="{DynamicResource TextBrushDarker}"
                      Typography.Capitals="AllSmallCaps" />

                    <Separator Background="{DynamicResource WindowPanelSeparatorBrush}" />

                    <Grid Margin="0,5,0,10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                      </Grid.RowDefinitions>
                      <Grid.Resources>
                        <Style BasedOn="{StaticResource BaseTextBlockStyle}" TargetType="TextBlock">
                          <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                        <Style
                          x:Key="Icon"
                          BasedOn="{StaticResource BaseTextBlockStyle}"
                          TargetType="TextBlock">
                          <Setter Property="Width" Value="24" />
                          <Setter Property="FontFamily" Value="{StaticResource FontIcoFont}" />
                          <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}" />
                        </Style>
                        <Style
                          x:Key="MdStyleIcon"
                          BasedOn="{StaticResource BaseTextBlockStyle}"
                          TargetType="TextBlock">
                          <Setter Property="Width" Value="24" />
                          <Setter Property="FontFamily" Value="{StaticResource FontIcoFont}" />

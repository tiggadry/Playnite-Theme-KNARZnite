<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="DetailsViewGroupStyle" TargetType="{x:Type GroupItem}">
    <Setter Property="Foreground" Value="{DynamicResource TextBrushDarker}" />
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type GroupItem}">
          <ExpanderEx
            Background="Transparent" BorderThickness="0"
            IsExpanded="True"
            SaveGameGroupId="{Binding Name, Mode=OneWay}">
            <ExpanderEx.Header>
              <Border
                Margin="0,5"
                BorderBrush="{DynamicResource WindowPanelSeparatorBrush}"
                BorderThickness="0,0,0,1">
                <DockPanel Margin="3,8" Background="Transparent">
                  <DockPanel.ContextMenu>
                    <GameGroupMenu />
                  </DockPanel.ContextMenu>
                  <TextBlock
                    DockPanel.Dock="Left"
                    Margin="0,0,5,0" HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeLarge}"
                    TextAlignment="Center" Typography.Capitals="AllSmallCaps">
                    <TextBlock.Style>
                      <Style BasedOn="{StaticResource BaseTextBlockStyle}" TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding Name, Converter={StaticResource ObjectToStringConverter}}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Name, Converter={StaticResource ObjectToStringConverter}}" Value="{x:Null}">
                            <Setter Property="Text" Value="{StaticResource LOCNone}" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Name, Converter={StaticResource ObjectToStringConverter}}" Value="">
                            <Setter Property="Text" Value="{StaticResource LOCNone}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <TextBlock
                    Style="{StaticResource BaseTextBlockStyle}"
                    DockPanel.Dock="Left"
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    Visibility="{Settings ShowGroupCount}"
                    Text="{Binding Items.Count, Mode=OneWay, StringFormat=({0})}"
                    Foreground="{DynamicResource GlyphBrush}"
                    TextAlignment="Center" />
                </DockPanel>
              </Border>
            </ExpanderEx.Header>
            <ItemsPresenter />
          </ExpanderEx>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="MainWindowStyle" TargetType="WindowBase">
    <Setter Property="Background" Value="{DynamicResource NormalBrushDark}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    <Setter Property="TextOptions.TextRenderingMode" Value="Auto" />
    <Setter Property="WindowChrome.WindowChrome">
      <Setter.Value>
        <WindowChrome
          CaptionHeight="25" CornerRadius="0"
          GlassFrameThickness="0" NonClientFrameEdges="None"
          ResizeBorderThickness="4" UseAeroCaptionButtons="False" />
      </Setter.Value>
    </Setter>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type WindowBase}">
          <ControlTemplate.Resources>
            <sys:Boolean x:Key="True">True</sys:Boolean>
          </ControlTemplate.Resources>
          <AdornerDecorator>
            <Border
              x:Name="WindowBorder"
              Background="{TemplateBinding Background}"
              BorderBrush="{DynamicResource PopupBorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="0">
              <Grid>
                <ContentPresenter Margin="0,0,0,0" />
                <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                  <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                    <TextBlock
                      x:Name="PART_TextTitle"
                      Style="{DynamicResource BaseTextBlockStyle}"
                      DockPanel.Dock="Left"
                      Margin="10,3,0,0" VerticalAlignment="Center"
                      Text="{TemplateBinding Title}"
                      Opacity="0.75" />
                    <StackPanel
                      DockPanel.Dock="Right"
                      Margin="0,3,5,0" VerticalAlignment="Center"
                      Orientation="Horizontal">
                      <Button
                        x:Name="PART_ButtonMinimize"
                        Style="{DynamicResource WindowBarButton}"
                        Content="0" />
                      <Button
                        x:Name="PART_ButtonMaximize"
                        Style="{DynamicResource WindowBarButton}"
                        Content="1" />
                      <Button
                        x:Name="PART_ButtonClose"
                        Style="{DynamicResource WindowBarButton}"
                        Content="r" />
                    </StackPanel>
                  </DockPanel>
                </DockPanel>
              </Grid>
            </Border>
          </AdornerDecorator>
          <ControlTemplate.Triggers>
            <Trigger Property="WindowState" Value="Maximized">
              <Setter Property="Content" TargetName="PART_ButtonMaximize" Value="2" />
              <Setter Property="Padding" TargetName="WindowBorder" Value="8" />
            </Trigger>
            <DataTrigger Binding="{Binding HasChildWindow, Mode=OneWay, RelativeSource={RelativeSource Self}, TargetNullValue=False}" Value="True">
              <Setter Property="BorderBrush" TargetName="WindowBorder" Value="{DynamicResource NormalBorderBrush}" />
              <Setter Property="Opacity" Value="0.4" />
            </DataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

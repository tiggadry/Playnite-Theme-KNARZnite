<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="DetailsViewItemTemplate" TargetType="{x:Type GameListItem}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type GameListItem}">
          <Border
            Margin="15,8,15,8"
            Background="Transparent" Name="PART_PanelHost">
            <DockPanel>
              <Image
                DockPanel.Dock="Left"
                Height="{Settings DetailsViewListIconSize}"
                Margin="0,0,0,0"
                Name="PART_ImageIcon" RenderOptions.BitmapScalingMode="Fant" />
            </DockPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="NotificationMessage" TargetType="Button">
    <Setter Property="Command" Value="{Binding ActivateCommand}" />
    <Setter Property="Margin" Value="10,8,10,0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border
            x:Name="NotificationMessageBorder"
            Style="{DynamicResource HighlightBorder}"
            Background="{DynamicResource GlyphBrush}"
            BorderThickness="0">
            <DockPanel>
              <Button
                DockPanel.Dock="Right"
                Padding="6,0,6,0" VerticalAlignment="Stretch"
                Command="{Binding CloseCommand}"
                Content="r"
                BorderThickness="0" FontFamily="Marlett" />
              <TextBlock
                Style="{DynamicResource BaseTextBlockStyle}"
                DockPanel.Dock="Left"
                MinHeight="38"
                Margin="6,6,0,6"
                Text="{Binding Text}"
                Foreground="{DynamicResource TextBrushDark}"
                TextWrapping="Wrap" />
            </DockPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

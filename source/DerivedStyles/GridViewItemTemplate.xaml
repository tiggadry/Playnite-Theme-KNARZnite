<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:p="clr-namespace:Playnite;assembly=Playnite"
  xmlns:popt="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="GridViewItemTemplate" TargetType="{x:Type GameListItem}">
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type GameListItem}">
          <Grid Margin="{Settings GridItemMargin}" Name="PART_PanelHost">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border BorderBrush="{DynamicResource PanelSeparatorBrush}" BorderThickness="1">
              <Border.CacheMode>
                <BitmapCache
                  EnableClearType="True" RenderAtScale="1"
                  SnapsToDevicePixels="False" />
              </Border.CacheMode>
              <Grid Width="{Settings GridItemWidth}">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ContentControl
                  x:Name="ThemeExtras_Banner"
                  Grid.Row="0"
                  Width="{Binding Width, ElementName=PART_ImageCover}"
                  HorizontalAlignment="Center" VerticalAlignment="Top"
                  Visibility="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource BooleanToVisibilityConverter}}"
                  Tag="{DynamicResource GridViewCoverDisplayLibraryBanner}"
                  RenderOptions.BitmapScalingMode="Fant" />

                <Grid
                  Grid.Row="1"
                  Width="Auto"
                  Height="{Settings GridItemHeight}">
                  <!--  Proxy for ThemeModifier constants  -->
                  <TextBlock
                    x:Name="ShineEnabledProxy"
                    Visibility="Collapsed"
                    Tag="{DynamicResource GridViewEnableCoverShineAnimation}" />
                  <TextBlock
                    x:Name="GlowEnabledProxy"
                    Visibility="Collapsed"
                    Tag="{DynamicResource GridViewEnablePlayingGlowBorder}" />
                  <!--  Glow border overlay  -->
                  <Border
                    x:Name="GlowBorderOverlay"
                    IsHitTestVisible="False"
                    BorderBrush="{DynamicResource GlyphBrush}"
                    BorderThickness="3" CornerRadius="0"
                    Opacity="0.0" />
                  <Image
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Name="PART_ImageCover" RenderOptions.BitmapScalingMode="Fant"
                    Stretch="{Settings CoverArtStretch}"
                    StretchDirection="Both" />
                  <!--  Shine animation overlay  -->
                  <Border
                    x:Name="CoverShineOverlay"
                    Visibility="Collapsed"
                    Background="Transparent">
                    <Rectangle
                      x:Name="ShineRect"
                      Fill="White" Opacity="0.0"
                      RadiusX="5" RadiusY="5" />
                  </Border>
                </Grid>
                 <Grid Grid.RowSpan="2">
                  <Border
                    x:Name="TextGameName"
                    Visibility="Collapsed"
                    Background="#99000000">
                    <TextBlock
                      Style="{StaticResource BaseTextBlockStyle}"
                      Margin="5" HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Text="{Binding DisplayName}"
                      TextAlignment="Center" TextTrimming="CharacterEllipsis"
                      TextWrapping="Wrap" />
                  </Border>
                  <Border
                    x:Name="BorderMouseOver"
                    Visibility="Collapsed"
                    Background="#AA000000" />
                </Grid>
                <Grid Grid.Row="1" Height="{Settings GridItemHeight}">
                  <ContentControl
                    x:Name="SuccessStory_PluginViewItem"
                    Margin="5" HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontWeight="Bold" Foreground="#FFFFFFFF"
                    SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display"
                    TextOptions.TextRenderingMode="ClearType" UseLayoutRounding="True">
                    <ContentControl.Effect>
                      <StaticResource ResourceKey="IconDropShadowEffect" />
                    </ContentControl.Effect>
                    <ContentControl.Resources>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#FFFFFFFF" />
                        <Setter Property="FontWeight" Value="Bold" />
                      </Style>
                      <Style TargetType="Label">
                        <Setter Property="Foreground" Value="#FFFFFFFF" />
                        <Setter Property="FontWeight" Value="Bold" />
                      </Style>
                    </ContentControl.Resources>
                  </ContentControl>
                  <DockPanel
                    Margin="5" HorizontalAlignment="Right"
                    VerticalAlignment="Top">
                    <TextBlock
                      DockPanel.Dock="Right"
                      Margin="3,0,0,0" VerticalAlignment="Center"
                      Text="&#xF000;"
                      Tag="{DynamicResource GridViewLibraryGameShowFavorite}"
                      FontFamily="{StaticResource FontIcoFont}"
                      FontSize="16"
                      Foreground="{DynamicResource FavoriteStarBrush}"
                      Opacity="0.75">
                      <!--  FavoriteStar Icon is Yellow  -->
                      <TextBlock.Effect>
                        <StaticResource ResourceKey="IconDropShadowEffect" />
                      </TextBlock.Effect>
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <MultiDataTrigger>
                              <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Favorite}" Value="True" />
                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True" />
                              </MultiDataTrigger.Conditions>
                              <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </DockPanel>
                  <Grid
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="Collapsed"
                    Name="GameControls">
                    <StackPanel
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Orientation="Vertical">
                      <Button
                        Width="60" Height="60"
                        Margin="0,0,0,2" HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Content="&#xec74;"
                        Tag="{DynamicResource HidePlayButtonForManualGames}"
                        FontFamily="{StaticResource FontIcoFont}"
                        FontSize="40" Name="PART_ButtonPlay">
                        <Button.Template>
                          <ControlTemplate TargetType="Button">
                            <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                              <TextBlock
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Text="{TemplateBinding Content}"
                                FontFamily="{TemplateBinding FontFamily}"
                                FontSize="{TemplateBinding FontSize}"
                                Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                          </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                          <Style BasedOn="{StaticResource SimpleButton}" TargetType="Button">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                              <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                  <Condition Binding="{Binding Game.IsCustomGame}" Value="True" />
                                  <Condition Binding="{Binding Game.IsInstalled}" Value="False" />
                                  <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}, FallbackValue=False}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Hidden" />
                              </MultiDataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Button.Style>
                      </Button>
                      <Button
                        Style="{StaticResource SimpleButton}"
                        Width="60" Height="60"
                        Margin="0" HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding Command, RelativeSource={RelativeSource Self}, Converter={StaticResource NullToVisibilityConverter}}"
                        Command="{PluginSettings Plugin=ThemeExtras,
                                                 Path=Commands.SwitchToDetailsViewCommand,
                                                 FallbackValue={x:Null}}"
                        CommandParameter="{Binding Game}"
                        Content="&#xE145;"
                        ToolTip="{DynamicResource LOCDetailsViewLabel}"
                        FontFamily="Segoe UI Symbol" FontSize="40"
                        Name="ButtonGridToDetails">
                        <Button.Template>
                          <ControlTemplate TargetType="Button">
                            <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                              <TextBlock
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Text="{TemplateBinding Content}"
                                FontFamily="{TemplateBinding FontFamily}"
                                FontSize="{TemplateBinding FontSize}"
                                Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                          </ControlTemplate>
                        </Button.Template>
                      </Button>
                    </StackPanel>
                  </Grid>
                  <!--  #DuplicateHider Source Icons Visible  -->
                  <!--
                    ContentControl2 host for DuplicateHider custom element in Grid view.
                    Uses a wrap-capable template so icons can flow into multiple rows
                    when a game has more sources than fit into a single line.
                    The plugin reads the style key from Tag (DuplicateHider_ContentControlWrapGridStyle2).
                  -->
                  <DockPanel
                    Margin="0,0,0,5" HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Name="GameSources">
                    <ContentControl
                      x:Name="DuplicateHider_ContentControl2"
                      MaxWidth="{Settings GridItemWidth}"
                      HorizontalAlignment="Center" VerticalAlignment="Bottom"
                      Tag="{DynamicResource DuplicateHider_ContentControlWrapGridStyle2}"
                      RenderOptions.BitmapScalingMode="Fant" />
                  </DockPanel>
                </Grid>
              </Grid>
            </Border>
            <TextBlock
              x:Name="ShowGameName"
              Style="{StaticResource BaseTextBlockStyle}"
              Grid.Row="1"
              Width="{Settings GridItemWidth}"
              Padding="2,5,2,5" VerticalAlignment="Center"
              Visibility="{Settings ShowNamesUnderCovers}"
              Text="{Binding DisplayName}"
              Foreground="{DynamicResource TextBrush}"
              TextAlignment="Center" TextTrimming="CharacterEllipsis" />

            <!--  Subtitle below the cover: play time in Grid View  -->
            <!--  Visibility is controlled by the ThemeModifier constant GridViewCoverSubtitleVisibility  -->
            <DockPanel
              Grid.Row="2"
              Width="{Settings GridItemWidth}"
              Margin="5,0,5,0"
              Visibility="{DynamicResource GridViewCoverSubtitleVisibility}"
              Background="Transparent">
              <!--  Play time icon  -->
              <TextBlock
                Margin="0,0,0,-2" Padding="2,4,2,5"
                VerticalAlignment="Center"
                Text="&#xEEDC;"
                FontFamily="{StaticResource FontIcoFont}"
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{DynamicResource GridViewCoverSubtitleBrush}"
                TextAlignment="Left" />
              <!--  Play time value converted via PlayTimeToStringConverter  -->
              <TextBlock
                Style="{DynamicResource BaseTextBlockStyle}"
                Padding="3,4,2,2" VerticalAlignment="Center"
                Text="{Binding Playtime, Mode=OneWay, Converter={StaticResource PlayTimeToStringConverter}, IsAsync=True}"
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{DynamicResource GridViewCoverSubtitleBrush}"
                TextAlignment="Left" TextTrimming="CharacterEllipsis" />
            </DockPanel>
            <!--  Subtitle below the cover: Completion Status in Grid View  -->
            <!--  Display is controlled by the ThemeModifier constant GridViewCoverCompStatusSubtitleVisibility  -->
            <DockPanel
              Grid.Row="3"
              Width="{Settings GridItemWidth}"
              Margin="5,0,5,0"
              Tag="{DynamicResource GridViewCoverCompStatusSubtitleVisibility}"
              Background="{DynamicResource GridItemBackgroundBrush}">
              <DockPanel.Style>
                <Style TargetType="DockPanel">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <!--  If the game does not have Completion Status, the row is hidden  -->
                    <DataTrigger Binding="{Binding CompletionStatus.Name, TargetNullValue='', FallbackValue=''}" Value="">
                      <Setter Property="Visibility" Value="Hidden" />
                    </DataTrigger>
                    <!--  ThemeModifier switch: Collapsed => completely hide  -->
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Collapsed">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </DockPanel.Style>
              <TextBlock
                Margin="0,0,0,-2" Padding="2,4,2,5"
                VerticalAlignment="Center"
                Text="&#xEED6;"
                FontFamily="{StaticResource FontIcoFont}"
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{DynamicResource GridViewCoverSubtitleBrush}"
                TextAlignment="Left" />
              <TextBlock
                x:Name="CompletionStatusName"
                Style="{DynamicResource BaseTextBlockStyle}"
                Padding="3,4,2,2" VerticalAlignment="Center"
                Text="{Binding CompletionStatus.Name, Mode=OneWay, IsAsync=True}"
                ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}"
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{DynamicResource GridViewCoverSubtitleBrush}"
                TextAlignment="Left" TextTrimming="CharacterEllipsis" />
            </DockPanel>
          </Grid>
          <ControlTemplate.Triggers>
            <!--  Shine animation logic  -->
            <MultiDataTrigger>
              <MultiDataTrigger.Conditions>
                <Condition Binding="{Binding Tag, ElementName=ShineEnabledProxy}" Value="True" />
                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
              </MultiDataTrigger.Conditions>
              <Setter Property="Visibility" TargetName="CoverShineOverlay" Value="Visible" />
              <MultiDataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      AutoReverse="True" Duration="0:0:0.2"
                      From="0.0" Storyboard.TargetName="ShineRect"
                      Storyboard.TargetProperty="Opacity" To="0.35" />
                  </Storyboard>
                </BeginStoryboard>
              </MultiDataTrigger.EnterActions>
              <MultiDataTrigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      Duration="0:0:0.2" Storyboard.TargetName="ShineRect"
                      Storyboard.TargetProperty="Opacity" To="0.0" />
                  </Storyboard>
                </BeginStoryboard>
              </MultiDataTrigger.ExitActions>
            </MultiDataTrigger>
            <!--  Glow border animation logic  -->
            <MultiDataTrigger>
              <MultiDataTrigger.Conditions>
                <Condition Binding="{Binding Tag, ElementName=GlowEnabledProxy}" Value="True" />
                <Condition Binding="{Binding Game.IsRunning}" Value="True" />
              </MultiDataTrigger.Conditions>
              <MultiDataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      AutoReverse="True" Duration="0:0:0.3"
                      From="0.0" RepeatBehavior="Forever"
                      Storyboard.TargetName="GlowBorderOverlay" Storyboard.TargetProperty="Opacity"
                      To="1.0" />
                  </Storyboard>
                </BeginStoryboard>
              </MultiDataTrigger.EnterActions>
              <MultiDataTrigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      Duration="0:0:0.2" Storyboard.TargetName="GlowBorderOverlay"
                      Storyboard.TargetProperty="Opacity" To="0.0" />
                  </Storyboard>
                </BeginStoryboard>
              </MultiDataTrigger.ExitActions>
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding IsInstalled}" Value="False">
              <Setter Property="Content" TargetName="PART_ButtonPlay" Value="&#xef08;" />
            </DataTrigger>
            <MultiDataTrigger>
              <MultiDataTrigger.Conditions>
                <Condition Binding="{Binding IsInstalled}" Value="False" />
                <Condition Binding="{Settings DarkenUninstalledGamesGrid}" Value="True" />
              </MultiDataTrigger.Conditions>
              <Setter Property="Visibility" TargetName="BorderMouseOver" Value="Visible" />
            </MultiDataTrigger>
            <MultiDataTrigger>
              <MultiDataTrigger.Conditions>
                <Condition Binding="{Binding CoverImage}" Value="{x:Null}" />
                <Condition Binding="{Settings ShowNameEmptyCover}" Value="True" />
              </MultiDataTrigger.Conditions>
              <Setter Property="Visibility" TargetName="TextGameName" Value="Visible" />
            </MultiDataTrigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Visibility" TargetName="BorderMouseOver" Value="Visible" />
              <Setter Property="Visibility" TargetName="GameControls" Value="Visible" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!--
    DuplicateHider style for selector #1 (Details view host: DuplicateHider_SourceSelector1).
    Wiring: host content comes from Views/DetailsViewGameOverview.xaml and uses this style key by plugin contract.
    Resource dependencies: SemiTransparentHighlightBrush (background contrast).
    Keeps source icons readable on mixed backgrounds while preserving fallback-like behavior:
    - dim uninstalled versions,
    - highlight hovered and currently selected source,
    - keep subtle always-on backdrop for contrast.
  -->
  <Style
    x:Key="DuplicateHider_IconContentControlStyle1"
    BasedOn="{StaticResource {x:Type ContentControl}}"
    TargetType="ContentControl">
    <Setter Property="BorderBrush" Value="{x:Null}" />
    <Setter Property="Foreground" Value="{x:Null}" />
    <Setter Property="Background" Value="{x:Null}" />
    <Setter Property="Padding" Value="0,0,0,0" />
    <Setter Property="Margin" Value="0,0,0,0" />
    <Setter Property="BorderThickness" Value="0,0,0,0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContentControl">
          <Grid>
            <Border
              x:Name="IconBackground"
              Visibility="Visible"
              Background="{DynamicResource SemiTransparentHighlightBrush}"
              CornerRadius="8" Opacity="0.2" />
            <Image
              x:Name="SourceIcon"
              Margin="5"
              Opacity="0.95" RenderOptions.BitmapScalingMode="Fant"
              Source="{Binding Icon}" />
          </Grid>
          <ControlTemplate.Triggers>
            <!--  Match fallback behavior: uninstalled copies are dimmed.  -->
            <DataTrigger Binding="{Binding Game.IsInstalled}" Value="False">
              <Setter Property="Image.Opacity" TargetName="SourceIcon" Value="0.65" />
            </DataTrigger>
            <!--  Hover state: brighten icon and show stronger backdrop.  -->
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Border.Visibility" TargetName="IconBackground" Value="Visible" />
              <Setter Property="Border.Background" TargetName="IconBackground" Value="{DynamicResource SemiTransparentHighlightBrush}" />
              <Setter Property="Border.Opacity" TargetName="IconBackground" Value="0.75" />
              <Setter Property="Image.Effect" TargetName="SourceIcon">
                <Setter.Value>
                  <DropShadowEffect
                    BlurRadius="5" Color="White"
                    Opacity="1" RenderingBias="Performance"
                    ShadowDepth="0" />
                </Setter.Value>
              </Setter>
            </Trigger>
            <!--  Current (selected) source version highlight.  -->
            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
              <Setter Property="Border.Visibility" TargetName="IconBackground" Value="Visible" />
              <Setter Property="Border.Background" TargetName="IconBackground" Value="{DynamicResource SemiTransparentHighlightBrush}" />
              <Setter Property="Border.Opacity" TargetName="IconBackground" Value="1" />
            </DataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!--
    DuplicateHider icon style variant for grid source entries (#2).
    Wiring: consumed by DuplicateHider_ContentControlWrapGridStyle2 for each item in DataContext.Games.
    Resource dependencies: SemiTransparentHighlightBrush (hover/current backdrop).
    Used by the wrap-capable ContentControl2 template below for consistent hover/current visuals.
  -->
  <Style
    x:Key="DuplicateHider_IconContentControlStyle2"
    BasedOn="{StaticResource {x:Type ContentControl}}"
    TargetType="ContentControl">
    <Setter Property="BorderBrush" Value="{x:Null}" />
    <Setter Property="Foreground" Value="{x:Null}" />
    <Setter Property="Background" Value="{x:Null}" />
    <Setter Property="Padding" Value="0,0,0,0" />
    <Setter Property="Margin" Value="2,0,2,0" />
    <Setter Property="BorderThickness" Value="0,0,0,0" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Width" Value="30" />
    <Setter Property="Height" Value="30" />
    <Setter Property="MaxWidth" Value="30" />
    <Setter Property="MaxHeight" Value="30" />
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContentControl">
          <Grid>
            <Border
              x:Name="IconBackground"
              Visibility="Hidden"
              Background="{DynamicResource SemiTransparentHighlightBrush}"
              CornerRadius="8" Opacity="0.0" />
            <Image
              x:Name="SourceIcon"
              Margin="3"
              Opacity="0.95" RenderOptions.BitmapScalingMode="Fant"
              Source="{Binding Icon}" />
          </Grid>
          <ControlTemplate.Triggers>
            <!--  Match fallback behavior: uninstalled copies are dimmed.  -->
            <DataTrigger Binding="{Binding Game.IsInstalled}" Value="False">
              <Setter Property="Image.Opacity" TargetName="SourceIcon" Value="0.65" />
            </DataTrigger>
            <!--  Hover state: temporary backdrop + light glow for legibility.  -->
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Border.Visibility" TargetName="IconBackground" Value="Visible" />
              <Setter Property="Border.Background" TargetName="IconBackground" Value="{DynamicResource SemiTransparentHighlightBrush}" />
              <Setter Property="Border.Opacity" TargetName="IconBackground" Value="0.75" />
              <Setter Property="Image.Effect" TargetName="SourceIcon">
                <Setter.Value>
                  <DropShadowEffect
                    BlurRadius="3" Color="White"
                    Opacity="0.75" RenderingBias="Performance"
                    ShadowDepth="0" />
                </Setter.Value>
              </Setter>
            </Trigger>
            <!--  Current (selected) source version highlight.  -->
            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
              <Setter Property="Border.Visibility" TargetName="IconBackground" Value="Visible" />
              <Setter Property="Border.Background" TargetName="IconBackground" Value="{DynamicResource SemiTransparentHighlightBrush}" />
              <Setter Property="Border.Opacity" TargetName="IconBackground" Value="1" />
            </DataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!--
    DuplicateHider ContentControl style for grid selector #2.
    Wiring: assigned via Tag on DuplicateHider_ContentControl2 host in this template.
    Renders DataContext.Games via WrapPanel so source icons can span multiple rows.
    Each icon reuses DuplicateHider_IconContentControlStyle2 for consistent visuals.
  -->
  <Style x:Key="DuplicateHider_ContentControlWrapGridStyle2" TargetType="ContentControl">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContentControl">
          <ItemsControl ItemsSource="{Binding Games}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel HorizontalAlignment="Center" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <ContentControl Style="{DynamicResource DuplicateHider_IconContentControlStyle2}">
                  <ContentControl.InputBindings>
                    <MouseBinding Command="{Binding SelectCommand}" Gesture="LeftClick" />
                    <MouseBinding Command="{Binding LaunchCommand}" Gesture="LeftDoubleClick" />
                  </ContentControl.InputBindings>
                </ContentControl>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>

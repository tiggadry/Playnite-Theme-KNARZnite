<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style TargetType="{x:Type Thumb}">
    <Setter Property="Width" Value="Auto" />
    <Setter Property="Height" Value="Auto" />
    <Setter Property="Background" Value="{DynamicResource OpaqueNormalBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Thumb}">
          <Grid>
            <Rectangle
              x:Name="HoverRectangle"
              Width="{TemplateBinding Width}"
              Height="{TemplateBinding Height}"
              MinHeight="10"
              Margin="0" HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Fill="{TemplateBinding Background}"
              RadiusX="4" RadiusY="4"
              Stroke="{x:Null}" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsFocused" Value="True" />
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Fill" TargetName="HoverRectangle" Value="{DynamicResource GlyphBrush}" />
            </Trigger>
            <DataTrigger Binding="{Binding IsFocused, RelativeSource={RelativeSource AncestorType=Track}}" Value="True">
              <Setter Property="Fill" TargetName="HoverRectangle" Value="{DynamicResource GlyphBrush}" />
            </DataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SliderThumb" TargetType="{x:Type Thumb}">
    <Setter Property="Width" Value="Auto" />
    <Setter Property="Height" Value="Auto" />
    <Setter Property="Background" Value="{DynamicResource GlyphBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Thumb}">
          <Grid>
            <Rectangle
              x:Name="HoverRectangle"
              Width="{TemplateBinding Width}"
              Height="{TemplateBinding Height}"
              MinHeight="10"
              Margin="0" HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Fill="{TemplateBinding Background}"
              RadiusX="8" RadiusY="8"
              Stroke="{x:Null}" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsFocused" Value="True" />
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Fill" TargetName="HoverRectangle" Value="{DynamicResource HighlightGlyphBrush}" />
            </Trigger>
            <DataTrigger Binding="{Binding IsFocused, RelativeSource={RelativeSource AncestorType=Track}}" Value="True">
              <Setter Property="Fill" TargetName="HoverRectangle" Value="{DynamicResource HighlightGlyphBrush}" />
            </DataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

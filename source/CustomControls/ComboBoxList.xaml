<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ControlTemplate x:Key="ComboBoxListBaseTemplate" TargetType="{x:Type ComboBoxListBase}">
    <Border
      x:Name="Root"
      Style="{DynamicResource HighlightBorder}"
      Background="{DynamicResource ControlBackgroundBrush}"
      BorderThickness="{DynamicResource ControlBorderThickness}"
      CornerRadius="{DynamicResource ControlCornerRadius}"
      Cursor="Hand">
      <Grid>
        <DockPanel>
          <Viewbox DockPanel.Dock="Right" Margin="0,0,2,0">
            <TextBlock
              VerticalAlignment="Center"
              Text="6"
              FontFamily="Marlett"
              Foreground="{DynamicResource GlyphBrush}" />
          </Viewbox>
          <TextBlock
            x:Name="PART_TextFilterString"
            Style="{StaticResource BaseTextBlockStyle}"
            DockPanel.Dock="Left"
            Margin="5,0,0,0" HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            TextTrimming="CharacterEllipsis" />
        </DockPanel>
        <ToggleButton
          x:Name="MainToggle"
          Background="Transparent" BorderThickness="0"
          Focusable="False" HorizontalContentAlignment="Stretch">
          <ToggleButton.Style>
            <Style TargetType="ToggleButton">
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border Background="Transparent">
                      <ContentPresenter />
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ToggleButton.Style>
        </ToggleButton>
        <Button
          x:Name="PART_ButtonClearFilter"
          Margin="0,0,20,0" Padding="3,0,3,0"
          HorizontalAlignment="Right"
          Background="Transparent" BorderThickness="0"
          ContentTemplate="{DynamicResource ClearTextIconTemplate}"
          FontSize="18">
          <Button.Style>
            <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, ElementName=Root}" Value="True">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
        <Popup
          MinWidth="{Binding ActualWidth, ElementName=MainToggle}"
          MaxHeight="300"
          AllowsTransparency="True" Focusable="False"
          IsOpen="{Binding IsChecked, ElementName=MainToggle, Mode=TwoWay, Delay=100}"
          Name="Popup" Placement="Bottom"
          StaysOpen="False">
          <Border
            Background="{DynamicResource PopupBackgroundBrush}"
            BorderBrush="{DynamicResource PopupBorderBrush}"
            BorderThickness="{DynamicResource PopupBorderThickness}">
            <ItemsControl x:Name="PART_ItemsPanel" />
          </Border>
        </Popup>
      </Grid>
    </Border>
  </ControlTemplate>

  <ControlTemplate x:Key="FilterComboBoxListTemplate" TargetType="{x:Type ComboBoxListBase}">
    <Border
      x:Name="Root"
      Style="{DynamicResource HighlightBorder}"
      Background="{DynamicResource ControlBackgroundBrush}"
      BorderThickness="{DynamicResource ControlBorderThickness}"
      CornerRadius="{DynamicResource ControlCornerRadius}"
      Cursor="Hand">
      <Grid>
        <DockPanel>
          <Viewbox DockPanel.Dock="Right" Margin="0,0,2,0">
            <TextBlock
              VerticalAlignment="Center"
              Text="6"
              FontFamily="Marlett"
              Foreground="{DynamicResource GlyphBrush}" />
          </Viewbox>
          <TextBlock
            x:Name="PART_TextFilterString"
            Style="{StaticResource BaseTextBlockStyle}"
            DockPanel.Dock="Left"
            Margin="5,0,0,0" HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            TextTrimming="CharacterEllipsis" />
        </DockPanel>
        <ToggleButton
          x:Name="MainToggle"
          Background="Transparent" BorderThickness="0"
          Focusable="False" HorizontalContentAlignment="Stretch">
          <ToggleButton.Style>
            <Style TargetType="ToggleButton">
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border Background="Transparent">
                      <ContentPresenter />
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ToggleButton.Style>
        </ToggleButton>
        <Button
          x:Name="PART_ButtonClearFilter"
          Margin="0,0,20,0" Padding="3,0,3,0"
          HorizontalAlignment="Right"
          Background="Transparent" BorderThickness="0"
          ContentTemplate="{DynamicResource ClearTextIconTemplate}"
          FontSize="18">
          <Button.Style>
            <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, ElementName=Root}" Value="True">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
        <Popup
          MinWidth="{Binding ActualWidth, ElementName=MainToggle}"
          MaxHeight="300"
          AllowsTransparency="True" Focusable="False"
          IsOpen="{Binding IsChecked, ElementName=MainToggle, Mode=TwoWay, Delay=100}"
          Name="Popup" Placement="Bottom"
          StaysOpen="False">
          <Border
            Background="{DynamicResource PopupBackgroundBrush}"
            BorderBrush="{DynamicResource PopupBorderBrush}"
            BorderThickness="{DynamicResource PopupBorderThickness}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <DockPanel
                Grid.Row="0"
                Margin="5"
                Name="PART_ElemSearchHost">
                <CheckBox
                  x:Name="PART_ToggleSelectedOnly"
                  DockPanel.Dock="Right"
                  ToolTip="{DynamicResource LOCOnlyItemsSelectedTooltip}"
                  FontFamily="{DynamicResource FontIcoFont}" />
                <SearchBox
                  x:Name="PART_SearchBox"
                  DockPanel.Dock="Left"
                  Margin="0,0,5,0" />
              </DockPanel>
              <ItemsControl x:Name="PART_ItemsPanel" Grid.Row="1" />
            </Grid>
          </Border>
        </Popup>
      </Grid>
    </Border>
  </ControlTemplate>

  <Style
    x:Key="ComboBoxListItemStyle"
    BasedOn="{StaticResource {x:Type CheckBox}}"
    TargetType="{x:Type CheckBox}">
    <Setter Property="Padding" Value="5" />
  </Style>

  <Style TargetType="{x:Type ComboBoxList}">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Template" Value="{DynamicResource ComboBoxListBaseTemplate}" />
  </Style>

  <Style TargetType="{x:Type DdItemListSelectionBox}">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Template" Value="{DynamicResource FilterComboBoxListTemplate}" />
  </Style>
</ResourceDictionary>

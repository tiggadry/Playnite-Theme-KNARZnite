<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ControlTemplate x:Key="FilterSelectionBoxTemplate" TargetType="{x:Type FilterSelectionBoxBase}">
    <Border
      x:Name="Root"
      Style="{DynamicResource HighlightBorder}"
      Background="{DynamicResource ControlBackgroundBrush}"
      BorderThickness="{DynamicResource ControlBorderThickness}"
      CornerRadius="{DynamicResource ControlCornerRadius}">
      <Grid>
        <DockPanel>
          <Viewbox DockPanel.Dock="Right" Margin="0,0,2,0">
            <TextBlock
              VerticalAlignment="Center"
              Text="6"
              FontFamily="Marlett"
              Foreground="{DynamicResource GlyphBrush}" />
          </Viewbox>
          <TextBlock
            x:Name="PART_TextFilterString"
            Style="{StaticResource BaseTextBlockStyle}"
            DockPanel.Dock="Left"
            Margin="5,0,0,0" HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            TextTrimming="CharacterEllipsis" />
        </DockPanel>
        <ToggleButton
          x:Name="MainToggle"
          Background="Transparent" BorderThickness="0"
          Cursor="Hand" Focusable="False"
          HorizontalContentAlignment="Stretch">
          <ToggleButton.Style>
            <Style TargetType="ToggleButton">
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border Background="Transparent">
                      <ContentPresenter />
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ToggleButton.Style>
        </ToggleButton>
        <TextBox
          x:Name="PART_TextFilterInput"
          Margin="1,0,30,0" VerticalAlignment="Center"
          Background="Transparent" BorderThickness="0" />
        <Button
          x:Name="PART_ButtonClearFilter"
          Margin="0,0,20,0" Padding="3,0,3,0"
          HorizontalAlignment="Right"
          Background="Transparent" BorderThickness="0"
          ContentTemplate="{DynamicResource ClearTextIconTemplate}"
          FontSize="18">
          <Button.Style>
            <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, ElementName=Root}" Value="True">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
        <Popup
          MinWidth="{Binding ActualWidth, ElementName=MainToggle}"
          MaxHeight="300"
          AllowsTransparency="True" Focusable="False"
          IsOpen="{Binding IsChecked, ElementName=MainToggle, Mode=TwoWay, Delay=100}"
          Name="Popup" Placement="Bottom"
          StaysOpen="False">
          <Border
            Background="{DynamicResource PopupBackgroundBrush}"
            BorderBrush="{DynamicResource PopupBorderBrush}"
            BorderThickness="{DynamicResource PopupBorderThickness}">
            <ItemsControl x:Name="PART_ItemsPanel" />
          </Border>
        </Popup>
      </Grid>
    </Border>
  </ControlTemplate>

  <Style
    x:Key="FilterSelectionBoxItemStyle"
    BasedOn="{StaticResource {x:Type CheckBox}}"
    TargetType="{x:Type CheckBox}">
    <Setter Property="Padding" Value="5" />
  </Style>

  <Style TargetType="{x:Type FilterEnumSelectionBox}">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template" Value="{DynamicResource FilterSelectionBoxTemplate}" />
  </Style>

  <Style TargetType="{x:Type FilterStringSelectionBox}">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template" Value="{DynamicResource FilterSelectionBoxTemplate}" />
  </Style>

  <Style TargetType="{x:Type FilterSelectionBox}">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Template" Value="{DynamicResource FilterSelectionBoxTemplate}" />
  </Style>
</ResourceDictionary>

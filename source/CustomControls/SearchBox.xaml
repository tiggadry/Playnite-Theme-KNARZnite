<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style TargetType="{x:Type SearchBox}">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type SearchBox}">
          <Grid>
            <TextBox
              x:Name="PART_TextInpuText"
              Padding="5,0,25,0"
              VerticalContentAlignment="Center" />
            <ContentControl
              x:Name="PART_SeachIcon"
              Margin="8,0,0,0" HorizontalAlignment="Left"
              VerticalAlignment="Center"
              IsHitTestVisible="False"
              ContentTemplate="{DynamicResource SearchTextIconTemplate}"
              Foreground="{DynamicResource TextBrushDarker}" />
            <ContentControl
              x:Name="PART_ClearTextIcon"
              Margin="0,0,5,0" HorizontalAlignment="Right"
              VerticalAlignment="Center"
              ContentTemplate="{DynamicResource ClearTextIconTemplate}"
              Cursor="Hand" FontSize="18"
              Foreground="{DynamicResource TextBrushDarker}" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>

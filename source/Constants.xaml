<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Feature and View Settings -->
    <sys:Boolean x:Key="DetailsViewCoverDisplayLibraryBanner">True</sys:Boolean>
    <sys:Boolean x:Key="DetailsViewAllowUseOfLogos">True</sys:Boolean>
    <sys:Boolean x:Key="DetailsViewHideGameNameIfLogoVisible">True</sys:Boolean>
    <sys:Boolean x:Key="DetailsViewLibraryGameShowFavorite">True</sys:Boolean>
    <sys:Boolean x:Key="GridViewLibraryGameShowFavorite">True</sys:Boolean>
    <sys:Boolean x:Key="GridViewCoverZoomOnHover">False</sys:Boolean>
    <sys:Boolean x:Key="GridViewEnableCoverShineAnimation">False</sys:Boolean>
    <sys:Boolean x:Key="GridViewCoverDisplayLibraryBanner">True</sys:Boolean>
    <sys:Boolean x:Key="GridViewCoverUseRoundedCorners">True</sys:Boolean>
    <sys:Boolean x:Key="GridViewEnablePlayingGlowBorder">True</sys:Boolean>
    <sys:Boolean x:Key="HidePlayButtonForManualGames">False</sys:Boolean>
    <sys:Boolean x:Key="DisplayLinkBar">True</sys:Boolean>
    <sys:Boolean x:Key="LinkBarAsBox">True</sys:Boolean>
    <sys:Boolean x:Key="DisableDetailsSection">False</sys:Boolean>
    <sys:Boolean x:Key="ShowPlayTimeInButtonBar">False</sys:Boolean>
    <sys:Boolean x:Key="DisplayCompletionStatusComboBox">False</sys:Boolean>

    <Visibility x:Key="GridViewCoverSubtitleVisibility">Collapsed</Visibility>
    <Visibility x:Key="GridViewCoverCompStatusSubtitleVisibility">Collapsed</Visibility>

    <!-- Plugin Settings -->
    <sys:Int32 x:Key="DuplicateHider_MaxNumberOfIcons">0</sys:Int32>

    <!-- Dimensions -->
    <sys:Double x:Key="DetailsViewDetailsMaxWidth">1024</sys:Double>
    <sys:Double x:Key="WebExplorerControlHeight">800</sys:Double>

    <!-- Typography -->
    <sys:Double x:Key="FontSizeSmall">12</sys:Double>
    <sys:Double x:Key="FontSize">14</sys:Double>
    <sys:Double x:Key="FontSizeLarge">15</sys:Double>
    <sys:Double x:Key="FontSizeLarger">20</sys:Double>
    <sys:Double x:Key="FontSizeLargest">29</sys:Double>
    <FontFamily x:Key="FontFamily">Trebuchet MS</FontFamily>

    <!-- Thickness, Padding and Radius -->
    <Thickness x:Key="PopupBorderThickness">1</Thickness>
    <Thickness x:Key="ControlBorderThickness">1</Thickness>
    <sys:Double x:Key="EllipseBorderThickness">1</sys:Double>
    <sys:Double x:Key="ControlCornerRadiusValue">5</sys:Double>
    <CornerRadius x:Key="ControlCornerRadius"
        BottomLeft="{StaticResource ControlCornerRadiusValue}"
        BottomRight="{StaticResource ControlCornerRadiusValue}"
        TopLeft="{StaticResource ControlCornerRadiusValue}"
        TopRight="{StaticResource ControlCornerRadiusValue}" />
    <CornerRadius x:Key="ControlCornerRadiusSmall">0</CornerRadius>
    <CornerRadius x:Key="GridViewCoverGridBackgroundDisabledCornerRadius">5,5,0,0</CornerRadius>
    <CornerRadius x:Key="GridViewShowGameNameCornerRadius">0,0,5,5</CornerRadius>
    <CornerRadius x:Key="GridViewSelectionBorderCornerRadius">7</CornerRadius>

    <!-- Colors -->
    <Color x:Key="TextColor">#FFF2F2F2</Color>
    <Color x:Key="TextColorDarker">#FF848484</Color>
    <Color x:Key="TextColorDark">#FF262626</Color>
    <Color x:Key="MainColor">#FF000000</Color><!--#FF191919 -->
    <Color x:Key="MainColorDark">#FF333333</Color><!--#FF262626 -->
    <Color x:Key="MainColorDarker">#FF000000</Color><!--#FF121212 -->
    <Color x:Key="HoverColor">#FF003d48</Color>
    <Color x:Key="FavoriteStarColor">#ffff00</Color><!--#FavoriteStar Icon is Yellow -->
    <Color x:Key="GlyphColor">#FF3797a2</Color>
    <Color x:Key="HighlightGlyphColor">#FF6cc9d1</Color>
    <Color x:Key="PopupBackgroundColor">#FF191919</Color>
    <Color x:Key="PopupBorderColor">#FF121212</Color>
    <Color x:Key="GridItemBackgroundColor">#FF1F1F1F</Color>
    <Color x:Key="PanelSeparatorColor">#FF000000</Color><!--#FF1F1F1F -->
    <Color x:Key="WindowPanelSeparatorColor">#FF3797a2</Color><!--#FF262626 -->
    <Color x:Key="NormalBorderControlsHoverTransparencyColor">#4c919191</Color>

    <!-- Core Brushes -->
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{DynamicResource MainColorDarker}" />
    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}" />
    <SolidColorBrush x:Key="TextBrushDarker" Color="{DynamicResource TextColorDarker}" />
    <SolidColorBrush x:Key="TextBrushDark" Color="{DynamicResource TextColorDark}" />
    <SolidColorBrush x:Key="NormalBrush" Color="{DynamicResource MainColorDark}" />
    <SolidColorBrush x:Key="NormalBrushDark" Color="{DynamicResource MainColorDarker}" />
    <SolidColorBrush x:Key="NormalBorderBrush" Color="{DynamicResource MainColorDark}" />
    <SolidColorBrush x:Key="HoverBrush" Color="{DynamicResource HoverColor}" />
    <SolidColorBrush x:Key="FavoriteStar" Color="{DynamicResource FavoriteStarColor}" /><!--#FavoriteStar Icon is Yellow -->
    <SolidColorBrush x:Key="GlyphBrush" Color="{DynamicResource GlyphColor}" />
    <SolidColorBrush x:Key="HighlightGlyphBrush" Color="{DynamicResource HighlightGlyphColor}" />
    <SolidColorBrush x:Key="PopupBorderBrush" Color="{DynamicResource PopupBorderColor}" />
    <SolidColorBrush x:Key="TooltipBackgroundBrush" Color="{DynamicResource PopupBackgroundColor}" />
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{DynamicResource GridItemBackgroundColor}" />
    <SolidColorBrush x:Key="GridItemBackgroundBrush" Color="{DynamicResource GridItemBackgroundColor}" />
    <SolidColorBrush x:Key="PanelSeparatorBrush" Color="{DynamicResource PanelSeparatorColor}" />
    <SolidColorBrush x:Key="WindowPanelSeparatorBrush" Color="{DynamicResource WindowPanelSeparatorColor}" />
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="{DynamicResource PopupBackgroundColor}" />

    <!-- Semantic Brushes -->
    <SolidColorBrush x:Key="PositiveRatingBrush" Color="#78ffa0" />
    <SolidColorBrush x:Key="NegativeRatingBrush" Color="#FFFF6250" />
    <SolidColorBrush x:Key="MixedRatingBrush" Color="#FFFFD149" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FFFF6250" />

    <!-- Surface and Overlay Brushes -->
    <SolidColorBrush x:Key="ExpanderBackgroundBrush" Color="{DynamicResource HoverColor}" />
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{DynamicResource MainColor}" />
    <SolidColorBrush x:Key="OpaqueGrayHighlightBrush" Color="{DynamicResource NormalBorderControlsHoverTransparencyColor}" />
    <SolidColorBrush x:Key="OpaqueButtonBackgroundBrush" Color="{DynamicResource GridItemBackgroundColor}" Opacity="0.7" />
    <SolidColorBrush x:Key="OpaqueNormalBrush" Color="{DynamicResource MainColorDark}" Opacity="0.7" />

    <!-- Extras and Specialized Brushes -->
    <SolidColorBrush x:Key="Extras_FilledStarBrush" Color="{DynamicResource HighlightGlyphColor}"/>
    <SolidColorBrush x:Key="Extras_EmptyStarBrush" Color="{DynamicResource HighlightGlyphColor}" Opacity="0.5"/>
    <SolidColorBrush x:Key="GridViewCoverSubtitleBrush" Color="#b7b7b7" />

    <!-- Effects -->
    <DropShadowEffect x:Key="DefaultDropShadow" ShadowDepth="0" BlurRadius="10" Opacity="0.7" Color="Black" RenderingBias="Performance" />
    <DropShadowEffect x:Key="IconDropShadowEffect" ShadowDepth="2" BlurRadius="4" Direction="315" Color="Black" Opacity="1" RenderingBias="Performance" />
    <DropShadowEffect x:Key="DuplicateHiderSourceIconEffect" ShadowDepth="2" BlurRadius="1" Color="Black" Opacity="1" RenderingBias="Performance" />
    <DropShadowEffect x:Key="DefaultSubtleDropShadow" ShadowDepth="0" BlurRadius="6" Opacity="0.5" Color="Black" RenderingBias="Performance" />
    <DropShadowEffect x:Key="NoDropShadow" ShadowDepth="0" BlurRadius="0" Opacity="0" Color="Transparent" RenderingBias="Performance" />
</ResourceDictionary>

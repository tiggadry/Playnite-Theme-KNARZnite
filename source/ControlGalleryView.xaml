<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:pctrls="clr-namespace:Playnite.DesktopApp.Controls;assembly=Playnite.DesktopApp"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="ControlGalleryContentStyle" TargetType="{x:Type ContentControl}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ContentControl}">
          <DockPanel Background="{DynamicResource WindowBackgroundBrush}">
            <Menu DockPanel.Dock="Top">
              <MenuItem Header="_File">
                <MenuItem Header="_New" />
                <MenuItem IsEnabled="False" Header="Open" />
                <MenuItem
                  Header="Save"
                  IsCheckable="True" IsChecked="True" />
                <Separator />
                <MenuItem Header="Exit">
                  <MenuItem Header="Test" />
                  <MenuItem Header="Test2" />
                </MenuItem>
              </MenuItem>

              <MenuItem IsEnabled="False" Header="Test">
                <MenuItem Header="_New" />
              </MenuItem>

              <MenuItem Header="Test2">
                <MenuItem Header="New" />
              </MenuItem>
            </Menu>

            <TabControl TabStripPlacement="Top">
              <TabItem Header="Test">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="10">
                    <StackPanel Orientation="Horizontal">
                      <Button
                        Margin="5" HorizontalAlignment="Left"
                        Content="Button">
                        <Button.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Test1" />
                            <Separator />
                            <MenuItem Header="Test2">
                              <MenuItem Header="Test1" />
                            </MenuItem>
                          </ContextMenu>
                        </Button.ContextMenu>
                      </Button>
                      <RepeatButton
                        Margin="5" HorizontalAlignment="Left"
                        Content="RepeatButton"
                        ToolTip="Testing tooltip for a button" />
                      <ToggleButton
                        Margin="5" HorizontalAlignment="Left"
                        Content="ToggleButton" />
                    </StackPanel>

                    <UniformGrid Columns="2">
                      <CheckBox
                        Margin="5" HorizontalAlignment="Left"
                        Content="TestCheckbox"
                        IsChecked="True" IsThreeState="True" />
                      <TextBlock VerticalAlignment="Center">
                        <Hyperlink>
                          Hyperlink Click here
                        </Hyperlink>
                      </TextBlock>
                    </UniformGrid>
                    <UniformGrid Columns="2">
                      <ComboBox
                        Margin="5" HorizontalAlignment="Stretch"
                        Text="Test2"
                        IsEditable="True" />
                      <ComboBox
                        Margin="5" HorizontalAlignment="Stretch"
                        SelectedIndex="1">
                        <ComboBoxItem Content="Test1" />
                        <ComboBoxItem Content="Test2" />
                        <ComboBoxItem Content="Test3" />
                        <ComboBoxItem Content="Test1" />
                        <ComboBoxItem Content="Test2" />
                        <ComboBoxItem Content="Test3" />
                        <ComboBoxItem Content="Test1" />
                        <ComboBoxItem Content="Test2" />
                        <ComboBoxItem Content="Test3" />
                        <ComboBoxItem Content="Test1" />
                        <ComboBoxItem Content="Test2" />
                        <ComboBoxItem Content="Test3" />
                        <ComboBoxItem Content="Test1" />
                        <ComboBoxItem Content="Test2" />
                        <ComboBoxItem Content="Test3" />
                        <ComboBoxItem Content="Test1" />
                        <ComboBoxItem Content="Test2" />
                        <ComboBoxItem Content="Test3" />
                        <ComboBoxItem Content="Test3" />
                        <ComboBoxItem Content="Test1" />
                        <ComboBoxItem Content="Test2" />
                        <ComboBoxItem Content="Test3" />
                        <ComboBoxItem Content="Test1" />
                        <ComboBoxItem Content="Test2" />
                        <ComboBoxItem Content="Test3" />
                        <ComboBoxItem Content="Test3" />
                        <ComboBoxItem Content="Test1" />
                      </ComboBox>
                    </UniformGrid>
                    <TextBlock Margin="5" Text="Test text just test text" />
                    <TextBox Margin="5" Text="Test text just test text" />
                    <TextBox
                      Height="50"
                      Margin="5"
                      Text="This TextBox will allow the user to enter multiple lines of text.  When the RETURN key is pressed, or when typed text reaches the edge of the text box, a new line is automatically inserted."
                      AcceptsReturn="True" TextWrapping="Wrap"
                      VerticalScrollBarVisibility="Auto" />
                    <PasswordBox Margin="5" Password="test" />
                    <Expander
                      Margin="5"
                      Header="TestExpander"
                      IsExpanded="True">
                      <ListView
                        Height="100"
                        Margin="5"
                        SelectedIndex="1"
                        Name="listview">
                        <ListView.View>
                          <GridView>
                            <GridViewColumn
                              Width="120"
                              Header="Name"
                              DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn
                              Width="50"
                              Header="Age"
                              DisplayMemberBinding="{Binding Age}" />
                            <GridViewColumn
                              Width="150"
                              Header="Mail"
                              DisplayMemberBinding="{Binding Mail}" />
                          </GridView>
                        </ListView.View>
                        <ListViewItem Content="Tea" />
                        <ListViewItem Content="Test" />
                      </ListView>
                    </Expander>
                    <ListBox
                      Height="100"
                      Margin="5"
                      SelectedIndex="1">
                      <ListBoxItem Content="ListItem 1" />
                      <ListBoxItem Content="ListItem 2" />
                      <ListBoxItem Content="ListItem 3" />
                      <ListBoxItem Content="ListItem 1" />
                      <ListBoxItem Content="ListItem 2" />
                      <ListBoxItem Content="ListItem 3" />
                      <ListBoxItem Content="ListItem 1" />
                      <ListBoxItem Content="ListItem 2" />
                      <ListBoxItem Content="ListItem 3" />
                    </ListBox>

                  </StackPanel>
                  <StackPanel Grid.Column="1">
                    <pctrls:NullIntNumericBox Margin="5" />
                    <pctrls:LongNumericBox Margin="5" />
                    <pctrls:SearchBox Margin="5" />
                    <pctrls:FilterSelectionBox Margin="5" />
                    <pctrls:DdItemListSelectionBox Margin="5" />

                    <GroupBox Margin="5" Header="Test Groubox">
                      <StackPanel>
                        <ProgressBar
                          Width="342" Height="20"
                          Margin="5"
                          Value="30" />
                        <RadioButton
                          Margin="5"
                          Content="RadioButton1"
                          GroupName="test" IsChecked="True" />
                        <RadioButton
                          Margin="5"
                          Content="RadioButton2"
                          GroupName="test" />
                      </StackPanel>
                    </GroupBox>

                    <TreeView Margin="5">
                      <TreeViewItem Header="Level 1" IsExpanded="True">
                        <TreeViewItem Header="Level 2.1" IsSelected="True" />
                        <TreeViewItem Header="Level 2.2" IsExpanded="True">
                          <TreeViewItem Header="Level 3.1" />
                          <TreeViewItem Header="Level 3.2" />
                        </TreeViewItem>
                        <TreeViewItem Header="Level 2.2" IsExpanded="False">
                          <TreeViewItem Header="Level 3.1" />
                          <TreeViewItem Header="Level 3.2" />
                        </TreeViewItem>
                      </TreeViewItem>
                    </TreeView>

                    <ScrollViewer
                      Width="100" Height="100"
                      Margin="5"
                      HorizontalScrollBarVisibility="Auto">
                      <Viewbox Width="200" Height="200">
                        <TextBlock Text="R" />
                      </Viewbox>
                    </ScrollViewer>
                  </StackPanel>
                </Grid>
              </TabItem>
              <TabItem Header="Test2" />
            </TabControl>
          </DockPanel>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
